// "전사트레이너"
SetNPC(12, 0x4001200E, 0x10000001, false, "NPC_M15.GCMDS", "이보이크스\\<전사 트레이너>");
SetPosition(0x4001200E, 5.000, 2885.59, 28.15, 2364.17);
SetNPCAttribute(0x4001200E, 16, 0 );
AddPopup(0x4001200E, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x4001200E, 104, 0, "전직하기", 0, 0 , 1);
AddPopup(0x4001200E, 401, 32, "파이터 스킬북", 0, 0 , 16715775);
AddWords(0x4001200E, "만나서 반갑군. 어떤 전투기술을 익히고 싶은가?");
AddDialog(0x4001200E, 1, 0, "파이터는 보다 전문적인 기술을 가지고 전투에 임하는 [디펜더]나 [워리어]로 가기위한 과정에 지나지 않아."); 
AddDialog(0x4001200E, 2, 0, "오호 드디어 보다 전문적인 전사로 거듭날 수 있을만큼 성장했군.\\하지만, 자넨 막 알에서 깨어난 병아리\\와 같은 상태지.\\자네가 당당한 왕국의 전사라고 불리기\\위해선 전직을 해야하지.\\어떤 직업으로 전직을 하냐고?\\전사인 자네는 워리어와 디펜더로 전직\\을 할 수가 있네.\\간단히 자네가 전직할 직업을 설명 하\\자면 먼저, 워리어는 말 그대로 막강한\\공격력으로 상대를 잠재우는 공격 중시\\형 전사라네.\\STR과 CON을 키우지만 막강한 공격\\력을 낼 수 있는 STR을 보다 중점적으\\로 키우는 클래스이지.\\물론, 자동으로 성장하는 능력도 매레\\벨마다 +2의 STR과 +1의 CON이 성장\\하지.\\반면, 디펜더는 튼튼한 방어력을 바탕\\으로 상대방을 제압하는 방어중시형의\\전사라네.\\역시 STR과 CON을 키우지만 양쪽이\\골고루 성장하는 클래스이지.\\성장하는 능력은 홀수 레벨에선 +2의\\STR과 +1의 CON이 짝수 레벨에선 +1\\의 STR과 +2의 CON이 성장하네.");

