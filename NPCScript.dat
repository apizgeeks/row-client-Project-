SetNPC(2, 0x40001049, 0x10000001, false, "NPC_A_officiator_t.GCMDS", "<오피세이터 트레이너>");
SetPosition(0x40001049, 1.453, 1965.54, 61.18, 1679.11);
SetNPCAttribute(0x40001049, 16, 2 );
AddPopup(0x40001049, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x40001049, 104, 0, "전직하기", 0, 0 , 131072);
AddPopup(0x40001049, 401, 83, "오피세이터 스킬북", 0, 0 , 16715775);
AddWords(0x40001049, "반갑습니다. 어떤 전투지식이 필요하신가요?");
AddDialog(0x40001049, 1, 0, "보다 깊숙한 전투지식의 연구를 위해선 10LV 이상으로 성장한 후 전직이라는 절차를 밟아야 합니다.\\만일 당신이 전직을 원한다면 데크라가 도움이 될 수 있을것 같군요.");
AddDialog(0x40001049, 2, 0, "어린 아칸이여 반갑습니다.\\이제 당신은 하나의 성체로서 인정을 받을\\수 있는 자격을 가졌습니다.\\하지만, 당신이 진실된 하나의 성체로 인정\\받으려면, 특수한 형태로 진화를 해야만 합\\니다.\\당신과 같은 오피세이터는 룬오프, 라이프\\오프, 그리고 쉐도우오프라 불리는 형태로\\진화를 할 수 있습니다.\\어떤 형태로 진화할지를 선택하기 전에 각\\각의 진화형태에 대해 설명을 해드리겠습\\니다.\\룬오프는 강력한 공격계열의 신비력을 사\\용할 수 있는 진화형태로서 매 레벨마다\\INT 2와 DEX 1 이 성장합니다.\\라이프오프는 회복에 관련된 신비력을 사\\용할 수 있는 진화형태로서 매 레벨마다\\WIS 2와 DEX 1이 성장합니다.\\쉐도우오프는 정찰과 암살등, 은밀한 행동\\이 가능하도록 진화된 형태로서 홀수레벨\\에선 STR 2와 DEX 1이, 짝수레벨에선 ST\\R 1과 DEX 2가 성장합니다.");
