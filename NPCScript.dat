SetNPC(1, 0x4000004D, 0x10000001, false, "NPC_M14.GCMDS", "키스케");
SetPosition(0x4000004D, 4.990, 1538.80, 15.65, 1980.31);
SetNPCAttribute(0x4000004D, 6, 1 );
AddPopup(0x4000004D, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000004D, "흠..오늘은 어디로 사냥을 갈까..");
AddDialog(0x4000004D, 1, 0, "이 주위에는 사냥할 장소는 많지만 대부분 위험한 몬스터들뿐이지.\\하지만, 위험한만큼 사냥이 성공했을때의 보상도 크지.\\내가 주로 사냥하는 몬스터는 고르곤과 트라이벌 그리고 '이란샤의 탑' 주위의 몬스터들이지.");
/// AddQuest(0x4000004D, 0x0020, 1, 9, 4095, 0, "tTesitio0102");
