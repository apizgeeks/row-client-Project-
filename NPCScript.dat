/// 유니테 물품보관소
SetNPC(2, 0x40001053, 0x10000001, false, "NPC_A_depositary.GCMDS", "<DragonTrans 센터>");
SetPosition(0x40001053, 2.126, 1980.56, 60.99, 1763.00 );
SetNPCAttribute(0x40001053, 19, 2 );
AddPopup(0x40001053, 10000, 0, "대화하기", 0, 0 , 16715775);
AddPopup(0x40001053, 10000, 0, "설명듣기", 0, 0 , 16715775);
AddPopup(0x40001053, 107, 0, "물품보관함", 0, 0 , 16715775);
AddWords(0x40001053, "어서오십시오. DragonTrans 물류센터입니다.");
AddDialog(0x40001053, 1, 0, "우리 수도에도 큰 규모의 DragonTrans센터가 들어서야할텐데..\\지금은 인간쪽에 본점을 뺏겼지만 언젠가는 반드시 유니테에 세울거요.");                          
AddDialog(0x40001053, 2, 0, "보관소를 처음 사용하시면 보관함 한개는 무료로 이용하실 수 있습니다.\\추가로 보관함을 이용하시려면 '사용불가'탭을 클릭하시면 보관함을 추가로 구입할 수 있습니다.\\ \\또한 저희는 물건을 맡길때마다 수수료를 받고 있습니다.\\맡길 물건은 신중히 선택해 주십시오.\\ \\비밀번호는 저장해 두시고 사용할 수 있지만 물건을 분실했을 경우 본사는 책임지지 않사오니 비밀번호를 잘 관리 해주시기 바랍니다.\\ \\비밀번호를 분실했을때에는 홈페이지로 문의해주시기 바랍니다.");

/// 유니테 대장장이
SetNPC(2, 0x40001066, 0x10000001, false, "NPC_A_blacksmith2.GCMDS", "<대장장이>");
SetPosition(0x40001066, 6.215, 2069.94, 60.00, 1650.54);
SetNPCAttribute(0x40001066, 18, 2 );
AddPopup(0x40001066, 10000, 0, "대화하기", 0, 0 , 16715775);
AddPopup(0x40001066, 102, 31, "제련", 0, 40 , 16715775);
AddPopup(0x40001066, 379, 0, "옵션이식", 0, 20 , 16715775);
AddWords(0x40001066, "어서오시오. 어떤 아이템을 제련하겠소?");
AddDialog(0x40001066, 1, 0, "나는 무기와 갑옷, 방패를 강화하는 작업을 하고있지.\\이는 매우 정밀한 작업이라 온도라던지 재료의 배합이라던지 하는 작업에서 약간의 오차만 있어도 실패한다네.\\하지만 늘 작품을 만든다는 생각으로 임하고 있다네.\\가끔 말도 못하게 피로가 쌓여 실패할때도 있지만 대부분의 고객은 만족하고 간다네.\\물론 성능이 좋은 아이템으로 개량할 수록 작업은 더욱더 어려워져서 궁극의 아이템을 만들기란 하늘의 별따기와 같다네.");
AddDialog(0x40001066, 2, 0, "강화하는법을 알려주지.\\먼저 강화할 아이템을 올려주게.\\각 단계별로 필요한 광물의 종류와 개수는 이렇다네.\\1단계: 실빈 3개\\2단계: 실빈 6개\\3단계: 실빈 9개\\4단계: 미스릴 3개\\5단계: 미스릴 6개\\6단계: 미스릴 9개\\7단계: 이터니움 3개\\8단계: 이터니움 6개\\9단계: 이터니움 9개\\아이템 강화란 더 좋은 아이템을 만들 수 있지만 실패 할 수도 있다네.");
/// AddQuest(0x40001066, 0x0024, 1, 9, 16711680, 0, "tUni0102");

