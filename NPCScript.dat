AddPopup(0x40000123, 401, 17, "방어구암시장", 0, 0 , 16715775);
AddWords(0x40000123, "자~ 여기서 좋은물건을 골라볼래요? 행운의 여신이 미소짓길 바래요.");
AddDialog(0x40000123, 1, 0, "사실 운이 좋은 사람이 특별히 따로 있는것 같기도 해요.\\어떤 사람은 정말 억세게 운이 좋아서 매번 좋은 물건을 건져가죠.\\그런 사람들이 많아지면 나도 돈벌기 곤란한데...");                          

