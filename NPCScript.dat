AddPopup(0x40003030, 401, 11, "무기상점", 0, 0 , 16715775);
AddWords(0x40003030, "어서 오게. 대륙에서 가져온 좋은 무기가 많으니 한번 보겠나?");
AddDialog(0x40003030, 1, 0, "이섬은 전에는 대륙과 연결되었다는\\설이 있다네. 하지만 어떤 사고를 계기로\\낮은 지대가 물에 잠기고 말았다는군.\\사실 대륙에 있는 이란샤의 탑도 훨씬더\\높은 위치에 있었음에 틀림없어.");
