// "크라우츠 대장장이"
SetNPC(8, 0x40008058, 0x10000004, false, "NPC_A_blacksmith2.GCMDS", "바트\\<대장장이>");
SetPosition(0x40008058, 0.307, 3267.08, 119.98, 3027.04);
SetNPCAttribute(0x40008058, 18, 2 );
AddPopup(0x40008058, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x40008058, 10000, 0, "설명듣기", 0, 0 , 16715775);
AddPopup(0x40008058, 102, 31, "제련하기", 0, 40 , 16715775);
AddPopup(0x40008058, 379, 0, "옵션이식", 0, 20 , 16715775);
AddWords(0x40008058, "어서오시오. 어떤 아이템을 제련하시겠소?");
AddDialog(0x40008058, 1, 0, "나는 무기와 갑옷, 방패를 강화하는 작업을 하고있지.\\이는 매우 정밀한 작업이라 온도라던지 재료의 배합이라던지 하는 작업에서 약간의 오차만 있어도 실패한다네.\\하지만 늘 작품을 만든다는 생각으로 임하고 있다네.\\가끔 말도 못하게 피로가 쌓여 실패할때도 있지만 대부분의 고객은 만족하고 간다네.\\물론 성능이 좋은 아이템으로 개량할 수록 작업은 더욱더 어려워져서 궁극의 아이템을 만들기란 하늘의 별따기와 같다네.");
AddDialog(0x40008058, 2, 0, "[제련에 관한 이야기]\\                                       \\제련은 [갑옷/무기/스킬암/방패] 타입에 해당하는 장비품을 강화시키는 작업을 말합니다.\\위의 장비품을 제련하기 위해선 특별한 광물 [실빈/미스릴/이터늄]등을 필요로 합니다.\\광물은 종류에 상관없이 1회의 제련시 마다 10개가 소모되며 각 광물은 [실빈<미스릴<이터늄]의 순으로 제련시 성공 확률이 높습니다.\\제련에 실패했을 경우 50%의 확률로 해당 장비품의 제련수치가 -1이 되며 소켓에 넣어진 보석이 사라지게 되니 주의하십시오.\\                                       \\                                       \\[옵션이식에 관한 이야기]\\                                       \\옵션 이식은 장비품이 지니고 있는 옵션을 다른 장비품의 옵션과 함하여 평균값을 취하게 만드는 것을 의미합니다.\\옵션이식은 [갑옷/무기/스킬암/방패] 타입의 장품만 가능하며 옵션을 받게될 [대상]이 되는 장비와 옵션을 줄 [제물]이 되는 장비가 필요합니다.\\옵션 이식은 실패할 확률이 없으며 옵션 이식을 끝냈을 경우 해당 장비품의 제련에 의한 수치와 소켓에 넣어진 보석에 의한 수치는 그대로 남아있게 됩니다.");


// "크라우츠 물품보관소"
SetNPC(8, 0x40008059, 0x10000004, false, "NPC_A_depositary.GCMDS", "브레그웬\\<DragonTrans 센터>");
SetPosition(0x40008059, 4.840, 3330.19, 122.00, 2988.20);
SetNPCAttribute(0x40008059, 19, 2 );
AddPopup(0x40008059, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x40008059, 10000, 0, "설명듣기", 0, 0 , 16715775);
AddPopup(0x40008059, 107, 0, "보관함 이용", 0, 0 , 16715775);
AddWords(0x40008059, "어서오십시오. DragonTrans 물류센터입니다.");
AddDialog(0x40008059, 1, 0, "그대와 같이 강한 전사들은 많은 물건들을 보관할 필요가 있지 않겠어요?\\음... 하지만 1인당 보관함은 4개밖에 대여해주지 않는답니다.\\귀한 물건만 보관하는게 낫겠어요.\\워낙 가진게 없다면 아무거나 넣어도 상관 없지만 말이에요!");                          
AddDialog(0x40008059, 2, 0, "보관소를 처음 사용하시면 보관함 한개는 무료로 이용하실 수 있습니다.\\추가로 보관함을 이용하시려면 '사용불가'탭을 클릭하시면 보관함을 추가로 구입할 수 있습니다.\\ \\또한 저희는 물건을 맡길때마다 수수료를 받고 있습니다.\\맡길 물건은 신중히 선택해 주십시오.\\ \\비밀번호는 저장해 두시고 사용할 수 있지만 물건을 분실했을 경우 본사는 책임지지 않사오니 비밀번호를 잘 관리 해주시기 바랍니다.\\ \\비밀번호를 분실했을때에는 홈페이지로 문의해주시기 바랍니다.");



