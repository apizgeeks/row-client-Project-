// "신의해적단 미들캠프 이동술사"
SetNPC(12, 0x4001208A, 0x10000001, false, "NPC_M16.GCMDS", "아로하논\\<카나번 미들캠프 행 항해사>");
SetPosition(0x4001208A, 2.034, 2734.0456, 9.64, 2459.1726);
SetNPCAttribute(0x4001208A, 17, 1 );
AddPopup(0x4001208A, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x4001208A, 105, 0, "카나번 미들캠프로", 0, 0 , 16715775);
AddWords(0x4001208A, "미들캠프로 갈건가?");
AddDialog(0x4001208A, 1, 0, "지금이야 어쨋든 자유와 평화를 상징하는 신의 대지의 영향인지 모르겠지만 예전의 카나번은 그야말로 단 한시도 전쟁을 멈춘적이 없는 위험한 대륙이었지.");
AddZoneMove(0x4001208A, 8, 1089.93, 100.00, 1039.47);


// "신의해적단 로슈캠프 이동술사"
SetNPC(12, 0x4001208B, 0x10000001, false, "NPC_A_blacksmith.GCMDS", "이코익\\<카나번 로슈캠프 행 항해사>");
SetPosition(0x4001208B, 1.514, 2737.26, 9.70, 2454.55);
SetNPCAttribute(0x4001208B, 17, 2 );
AddPopup(0x4001208B, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x4001208B, 105, 0, "카나번 로슈캠프로", 0, 0 , 16715775);
AddWords(0x4001208B, "카나번 대륙 메르카디아 진영의 로슈캠프로 가길 원하십니까?");
AddDialog(0x4001208B, 1, 0, "지금이야 어쨋든 자유와 평화를 상징하는 신의 대지의 영향인지 모르겠지만 예전의 카나번은 그야말로 단 한시도 전쟁을 멈춘적이 없는 위험한 대륙이었죠.");
AddZoneMove(0x4001208B, 8, 3060.23, 100.00, 1477.81);


// "신의해적단 그랜드 폴 포트리스 이동술사"
SetNPC(12, 0x4001208C, 0x10000001, false, "NPC_U_UnknownPirateGirl.GCMDS", "애브리스\\<카나번 그랜드 폴 포트리스 행 해적단 항해사>");
SetPosition(0x4001208C, 1.521, 2740.83, 9.70, 2450.39);
SetNPCAttribute(0x4001208C, 17, 0 );
AddPopup(0x4001208C, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x4001208C, 105, 0, "카나번 폴 포트리스로", 0, 0 , 16715775);
AddWords(0x4001208C, "카나번의 [그랜드 폴 포트리스]라면 내가 안내해 줄 수 있지.");
AddDialog(0x4001208C, 1, 0, "[신의 대지]에선 신기한 일이 많이 벌어졌었는데...\\그중에 하나는 [카르테란트]의 인간들과 [메르카디아]의 아칸들이 의기투합한 사건이지...\\그들은 카나번 대륙의 [그랜드 폴 계곡]에서 함께 힘을 모을 생각이었어.\\그러나 지금은 모든게 틀어져 버리고 말았지!");
AddZoneMove(0x4001208C, 8, 2286.42, 100.01, 1195.38);


