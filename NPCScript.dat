/// 테시티오 퀘스트용 추가 캐릭터
SetNPC(1, 0x4000005B, 0x10000001, false, "NPC_M15.GCMDS", "게일");
SetPosition(0x4000005B, 0.158, 1419.567, 8.26, 1992.58);
SetNPCAttribute(0x4000005B, 6, 1 );
AddPopup(0x4000005B, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000005B, "모험을 떠날 곳을 찾고 있는가?");
AddDialog(0x4000005B, 1, 0, "난, 세계의 여러 대륙을 모험했지..\\물론 여러번 죽을뻔한 고비도 있었지만 그만큼 내겐 많은 경험을 쌓고 강해 질 수 있었지.\\어떤가 자네도 내가 경험했던 모험에 도전하고 싶지 않은가?");
