SetNPC(1, 0x4000002F, 0x10000001, false, "NPC_M05.GCMDS", "브로스");
SetPosition(0x4000002F, 4.457, 1932.88, 24.12, 986.33);
SetNPCAttribute(0x4000002F, 6, 1 );
AddPopup(0x4000002F, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000002F, "이젠 같이 사냥할 사람을 찾아야 할텐데.. 괜찮은 실력을 가진 전사들이 안보이니...");
AddDialog(0x4000002F, 1, 0, "여기에선 가능하면 파티를 이루어서 사냥을 하게나.\\특히, 나와같은 마법사는 사냥시 내가 마법을 준비할동안 보호해줄 전사를 필요로 하지.");

SetNPC(1, 0x40000030, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x40000030, 4.263, 1919.98, 23.89, 1016.15);
SetNPCAttribute(0x40000030, 6, 1 );
AddPopup(0x40000030, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000030, "어서 오십시오. 그랜드코스트 지역의 남쪽 캠프 '첫번째 휴식'에 오신걸 환영합니다.");
AddDialog(0x40000030, 1, 0, "이 앞쪽에서 사냥을 할 수 있는 몬스터는 고블린 계열의 몬스터와 거대다람쥐, 그리고 거대한 벌래와 같은 몬스터입니다.\\특히, 고블린계열과 거대한 벌래는 선공 몬스터이니 주의하십시오.");

SetNPC(1, 0x40000031, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x40000031, 5.317, 1896.35, 26.85, 987.17);
SetNPCAttribute(0x40000031, 6, 1 );
AddPopup(0x40000031, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000031, "여기는 첫번째 휴식이라는 캠프입니다.");
AddDialog(0x40000031, 1, 0, "이 절벽을 따라서 가다보면 '사자의 계곡' 이라고 불리는 언데드류의 몬스터가 많이 나오는 계곡으로 갈 수 있습니다.\\캠프 주위와는 틀리게 아주 강력하고 선제 공격을 하는 몬스터들이 많으니 만약, 거기서 사냥을 하시겠다면 가능한 파티를 이루어서 가십시오.");

SetNPC(1, 0x40000032, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x40000032, 4.503, 1943.89, 23.95, 960.82);
SetNPCAttribute(0x40000032, 6, 1 );
AddPopup(0x40000032, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000032, "어서 오십시오. 여기는 첫번째 휴식이라 불리는 중간캠프입니다.");
AddDialog(0x40000032, 1, 0, "이 쪽의 언덕위로 올라가면 '사자의 계곡' 2층과 3층에 해당되는 언덕으로 갈 수 있습니다.\\2층까지는 어느정도 괜찮지만, 충분한 실력이나 파티를 이루지 않았다면, 3층에는 가지않는 것이 좋습니다.");

SetNPC(1, 0x40000033, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x40000033, 0.456, 1979.93, 23.85, 981.82);
SetNPCAttribute(0x40000033, 6, 1 );
AddPopup(0x40000033, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000033, "그랜드코스트 지역의 남쪽 캠프 '첫번째 휴식'에 오신걸 환영합니다.");
AddDialog(0x40000033, 1, 0, "이 캠프를 둘러싸고 있는 숲에는 거대 다람쥐와 고블린, 그리고 거대한 벌래들이 서식하고 있습니다.");

SetNPC(1, 0x40000034, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x40000034, 1.910, 1953.19, 23.92, 1024.25);
SetNPCAttribute(0x40000034, 6, 0 );
AddPopup(0x40000034, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000034, "어서 오십시오. 여기는 그랜드코스트 지역의 남쪽캠프 '첫번째 휴식'입니다.");
AddDialog(0x40000034, 1, 0, "이 앞쪽에 존재하는 강의 건너편은 '오래된숲'이라고 불리는 곳으로 여러종류의 몬스터들이 서식하는 곳입니다.\\혼자서 사냥하기엔 상당히 위험한 장소이니 가능하면 파티를 이루어서 사냥하도록 하십시오.");

SetNPC(1, 0x40000036, 0x10000001, false, "NPC_DONKEY.GCMDS", "당나귀");
