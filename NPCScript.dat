SetNPC(4, 0x40003024, 0x10000001, false, "NPC_W03.GCMDS", "반전단체 대표");
SetPosition(0x40003024, 3.884, 1995.80, 10.31, 1034.40);
SetNPCAttribute(0x40003024, 24, 0 );
AddPopup(0x40003024, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40003024, "반전단체 Peace.Of.World 에 오신걸 환영하오.");
AddDialog(0x40003024, 1, 0, "사실 이 대륙의 전쟁은 막기 힘든 현실이오.\\우리 반전단체의 힘으로 막을수 있을런지..\\하지만 우리의 신념은 변치 않소. 평화를 \\사랑하는 사람들을 지켜야만 하오. 적과 \\아군이 아닌 이대륙의 공존자로서 말이오.");
//AddQuest(0x40003024, 0x0116, 35, 48, 4095, 0x0115, "tNew3501"); // 1차 추가 퀘스트

//뉴베린 메달샵
