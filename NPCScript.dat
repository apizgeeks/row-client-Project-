AddPopup(0x40012081, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x40012081, "외부인이군요..반갑습니다.");
AddDialog(0x40012081, 1, 0, "이곳 [엘리오르]에 오신걸 환영합니다.\\요즘들어 인간족이라던지..아칸족들이 많이 찾아오는 군요..\\덕분에 무자비한 [세비지포쳐]들은 오지 않지만 말이죠..");


// "얼어붙은 초원 집앞"
SetNPC(12, 0x40012082, 0x10000001, false, "NPC_SnowMan.GCMDS", "패트로브\\<스노우림프 종족>");
SetPosition(0x40012082, 2.841, 1187.54, 134.08, 2872.17);
SetNPCAttribute(0x40012082, 6, 0 );
AddPopup(0x40012082, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x40012082, "반가습니다. 허허");
AddDialog(0x40012082, 1, 0, "[신의 대지]의 유일한 설원인 이곳은 [얼어붙은 초원]이라 불리지요.\\말 그대로 우리의 선조들이 이곳을 처음 발견 했을당시엔 이곳도 초원이었다고 하더이다. 허허");


// "얼어붙은 초원 집앞"
SetNPC(12, 0x40012083, 0x10000001, false, "NPC_SnowMan.GCMDS", "이누아르\\<스노우림프 종족>");
