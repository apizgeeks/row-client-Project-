SetNPC(1, 0x40000055, 0x10000001, false, "NPC_M11.GCMDS", "메이언");
SetPosition(0x40000055, 1.596, 1323.56, 16.94, 1979.68);
SetNPCAttribute(0x40000055, 6, 1 );
AddPopup(0x40000055, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000055, "어서 오십시오. 여기는 이 지역의 모험자들을 관리하는 모험자 길드입니다.");
AddDialog(0x40000055, 1, 0, "모험자 길드는 모험자 여러분들이 가진 직업의 전직에서부터 몬스터와의 전투에 필요한 기술의 전수에 이르기까지 모험자 여러분들에게 필요한 서비스를 제공하고 모험자 여러분들을 관리하는 곳입니다.");

SetNPC(1, 0x40000056, 0x10000001, false, "NPC_M11.GCMDS", "공무원");
SetPosition(0x40000056, 1.613, 1440.20, 9.71, 1905.84);
SetNPCAttribute(0x40000056, 6, 1 );
AddPopup(0x40000056, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000056, "어서 오십시오. 그랜드코스트 지역의 중앙도시 테시티오에 오신걸 환영합니다.");
AddDialog(0x40000056, 1, 0, "전 그랜드코스트 지역의 중앙도시인 '테시티오' 의 안내를 위해 왕국의 관리소에서 파견된 공무원입니다.");

