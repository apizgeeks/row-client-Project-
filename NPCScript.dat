/// 테시티오 물품보관소
SetNPC(1, 0x40000108, 0x10000001, false, "NPC_H_depositary.GCMDS", "<DragonTrans 본점>");
SetPosition(0x40000108, 1.543, 1461.73, 9.26, 1966.75);
SetNPCAttribute(0x40000108, 19, 1 );
AddPopup(0x40000108, 10000, 0, "대화하기", 0, 0 , 16715775);
AddPopup(0x40000108, 10000, 0, "설명듣기", 0, 0 , 16715775);
AddPopup(0x40000108, 107, 0, "물품보관함", 0, 0 , 16715775);
AddWords(0x40000108, "어서오십시오. DragonTrans 물류센터 본점입니다.");
AddDialog(0x40000108, 1, 0, "저희 물류센터는 용을 이용해서 물건을 다른 곳으로 보낸다고 합니다.\\저는 말단직원이라 그런 광경을 본적은 없죠...\\정말 보고싶어요.");                          
AddDialog(0x40000108, 2, 0, "보관소를 처음 사용하시면 보관함 한개는 무료로 이용하실 수 있구요.\\추가로 보관함을 이용하시려면 '사용불가' 탭을 클릭하시면 보관함을 추가로 구입할 수 있어요.\\ \\또한 저희는 물건을 맡길때마다 수수료를 받고 있답니다.\\맡길 물건은 신중히 선택해 주세요.\\ \\ 비밀번호는 저장해 두시고 사용할 수 있지만 물건을 분실했을 경우 본사는 책임지지 않사오니 비밀번호를 잘 관리 해주시기 바랍니다.\\ \\비밀번호를 분실했을때에는 홈페이지로  문의해주시기 바랍니다.");

/// 테시티오 물품보관소
SetNPC(1, 0x40000109, 0x10000001, false, "NPC_H_depositary.GCMDS", "<DragonTrans 본점>");
SetPosition(0x40000109, 2.303, 1459.78, 9.26, 1963.55);
SetNPCAttribute(0x40000109, 19, 1 );
AddPopup(0x40000109, 10000, 0, "대화하기", 0, 0 , 16715775);
AddPopup(0x40000109, 10000, 0, "설명듣기", 0, 0 , 16715775);
AddPopup(0x40000109, 107, 0, "물품보관함", 0, 0 , 16715775);
AddWords(0x40000109, "어서오십시오. DragonTrans 물류센터 본점입니다.");
AddDialog(0x40000109, 1, 0, "본점에서 일하기 위해서 10년동안 교육을 받았지요.\\물류센터에서 일하려면 체육과 산수는 필수랍니다.");                          
AddDialog(0x40000109, 2, 0, "보관소를 처음 사용하시면 보관함 한개는 무료로 이용하실 수 있구요.\\추가로 보관함을 이용하시려면 '사용불가' 탭을 클릭하시면 보관함을 추가로 구입할 수 있어요.\\ \\또한 저희는 물건을 맡길때마다 수수료를 받고 있답니다.\\맡길 물건은 신중히 선택해 주세요.\\ \\ 비밀번호는 저장해 두시고 사용할 수 있지만 물건을 분실했을 경우 본사는 책임지지 않사오니 비밀번호를 잘 관리 해주시기 바랍니다.\\ \\비밀번호를 분실했을때에는 홈페이지로  문의해주시기 바랍니다.");

