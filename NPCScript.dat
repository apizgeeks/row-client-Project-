SetNPC(1, 0x4000006F, 0x10000001, false, "NPC_M11.GCMDS", "안내원");
SetPosition(0x4000006F, 1.913, 1218.07, 51.18, 2112.87);
SetNPCAttribute(0x4000006F, 6, 1 );
AddPopup(0x4000006F, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000006F, "어서 오십시오. 여기는 모험자들간에 실력을 겨룰 수 있는 아레나입니다.");
AddDialog(0x4000006F, 1, 0, "......");

SetNPC(1, 0x40000070, 0x10000001, false, "NPC_W06.GCMDS", "테르시아");
SetPosition(0x40000070, 0.953, 1205.68, 50.85, 2151.61);
SetNPCAttribute(0x40000070, 6, 1 );
AddPopup(0x40000070, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000070, "난 지금 나와 싸울 상대와 이미지트레이닝 중이니 방해하지 말아주겠어?");
AddDialog(0x40000070, 1, 0, "흥. 내가 여자라고 깔보는 정말 재수없는 녀석이 있어서 투기장에서 한번 붙어보자고 결투를 신청하고 기다리는 중이야.\\나에게 지고도 그런 소리가 나오는지 보겠어.");

SetNPC(1, 0x40000071, 0x10000001, false, "NPC_M05.GCMDS", "리온");
SetPosition(0x40000071, 2.273, 1233.73, 52.72, 2162.10);
SetNPCAttribute(0x40000071, 6, 1 );
AddPopup(0x40000071, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000071, "아, 만나서 반갑네. 자네도 투기장을 구경하러 왔나?");
AddDialog(0x40000071, 1, 0, "이 곳은 모험자들의 실력을 겨룸으로서 서로에게 자극을 주기위해 만들어진 곳이지.\\하지만, 가끔은 모험자들간의 다툼을 해결하는 결투장소로 사용되기도 하지.");

SetNPC(1, 0x40000072, 0x10000001, false, "NPC_M14.GCMDS", "데이브");
SetPosition(0x40000072, 1.093, 1266.72, 50.36, 2094.13);
SetNPCAttribute(0x40000072, 6, 1 );
AddPopup(0x40000072, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000072, "이 치사한 녀석, 감히 내 먹이를 가로채다니..응? 자네에게 한말이 아니니 신경쓰지 말게나.");
AddDialog(0x40000072, 1, 0, "내말 좀 들어보겠나? 아, 글쎄 어떤 녀석이 내가 거의 다잡아 놓은 사냥물을 아무런 양해도 없이 죽여버리지 않겠나?\\모험자간의 사냥시에 지켜야할 가장 기본적인 룰도 지키지않다니.\\하도 화가 받아서 녀석에게 결투를 신청하고 여기서 기다리는 중이지.\\녀석에게 내가 모험자의 사냥시에 지켜야할 기본 예절에 대해 철저하게 알려주겠어!!");

