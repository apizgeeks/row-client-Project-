/// 알디아 NPC_03
SetNPC(1, 0x4000000D, 0x10000001, false, "NPC_M11.GCMDS", "안내원");
SetPosition(0x4000000D, 0.703, 2694.54, 22.95, 746.78);
SetNPCAttribute(0x4000000D, 6, 1 );
AddPopup(0x4000000D, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000000D, "어서 오십시오. 카르테란트 왕국 최전방 개척지인 그랜드코스트에 오신걸 환영합니다.");
AddDialog(0x4000000D, 1, 0, "전 '알디아 항구' 주위에 관해 안내를 하기위해 왕국의 관리소에서 파견된 공무원입니다.");

/// 알디아 NPC_04
SetNPC(1, 0x40000083, 0x10000001, false, "NPC_M04.GCMDS", "반전단체 대표");
SetPosition(0x40000083, 0.711, 2747.10, 23.40, 677.29);
SetNPCAttribute(0x40000083, 6, 1 );
AddPopup(0x40000083, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000083, "반전단체 Peace.Of.World 에 오신걸 환영하오.");
AddDialog(0x40000083, 1, 0, "사실 이 대륙의 전쟁은 막기 힘든 현실이오.\\우리 반전단체의 힘으로 막을수 있을런지..\\하지만 우리의 신념은 변치 않소.\\평화를 사랑하는 사람들을 지켜야만 하오.\\적과 아군이 아닌 이 대륙의 공존자로서 말이오.");
/// AddQuest(0x40000083, 0x0115, 35, 45, 4095, 0, "tAldia3501"); // 1차 추가 퀘스트

/// 알디아 길드관리대표
SetNPC(1, 0x4000000E, 0x10000001, false, "NPC_M11.GCMDS", "<길드관리대표>");
SetPosition(0x4000000E, 2.307, 2729.81, 24.24, 624.49);
SetNPCAttribute(0x4000000E, 28, 1 );
AddPopup(0x4000000E, 10000, 0, "설명듣기", 0, 0 , 16715775);
AddPopup(0x4000000E, 222, 0, "길드만들기", 0, 0 , 16715775);
AddWords(0x4000000E, "삶에선 잃지 말아야 할 여러가지가 있지만, 그중 하나는 자신 주변의 소중한 사람들이랍니다.");
AddDialog(0x4000000E, 1, 0, "●길드가입신청은 화면의 우하단 [길드]메\\ 뉴에서 가능합니다.\\●길드를 창단하려면 1000000(백만)Gold의\\ 화폐가 필요하며, 30LV 이상 되어야 합니\\ 다.\\\\\\●길드를 확장할때는 다음과 같은 조건\\을 만족시켜야 합니다.\\======================================\\  길드 명성치와 확장 가능 인원 제한 값\\--------------------------------------\\  필요명성치 | 제한인원 |    필요금액\\--------------------------------------\\             0   |     10     |   1,000,000\\        2000   |     20     |   5,000,000\\       10000   |     30     |  10,000,000\\       25000   |     40     |  50,000,000\\       50000   |     50     | 100,000,000\\======================================\\");

/// AddQuest(0x4000000E, 0xF115);
/// AddQuestWords(0x4000000E, 0xF115, "[카르테란트] 국가를 지향하시는 군요?");
/// AddQuest(0x4000000E, 0x0157 ); // "파트2 2차 퀘스트 업데이트"
/// AddQuestWords(0x4000000E, 0x0157 , "길드에 대해 설명이 필요한가요?"); // "파트2 2차 퀘스트 업데이트"

/// 알디아 NPC_05
SetNPC(1, 0x40000010, 0x10000001, false, "NPC_M08.GCMDS", "에릭");
SetPosition(0x40000010, 0.737, 2726.20, 23.80, 721.27);
SetNPCAttribute(0x40000010, 6, 1 );
AddPopup(0x40000010, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000010, "흠.. 탁 트인 바다라.. 정말 멋진 경관이지 않나?");
AddDialog(0x40000010, 1, 0, "난 여기서 바다를 바라보는 것을 좋아한다네.\\떠오르는 아침해에 빛나는 바다에서부터 한낮의 바다, 그리고 저녁노을이 질때의 붉은 빛에 감싸인 바다..\\언제나 변화하는 모습때문에 질리지가 않네.");
/// AddQuest(0x40000010, 0x0113, 35, 89, 4095, 0, "nAldia3501"); // 1차 추가 퀘스트

/// 알디아 NPC_06
SetNPC(1, 0x40000011, 0x10000001, false, "NPC_W06.GCMDS", "루실");
SetPosition(0x40000011, 2.073, 2728.06, 24.73, 674.65);
SetNPCAttribute(0x40000011, 6, 1 );
AddPopup(0x40000011, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000011, "알벤트는 누굴까요..");
AddDialog(0x40000011, 1, 0, "슬픈 [쿠이친]의 이야기..\\정체모를 [알벤트]라는 이로부터 오는 편지에 매번 적혀져 있군요..");

/// 알디아 NPC_07
SetNPC(1, 0x40000012, 0x10000001, false, "NPC_M14.GCMDS", "레이온");
SetPosition(0x40000012, 2.327, 2724.16, 24.10, 610.41);
SetNPCAttribute(0x40000012, 6, 1 );
AddPopup(0x40000012, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000012, "후훗..어떤가? 내모습은 정말 멋지지 않나?");
AddDialog(0x40000012, 1, 0, "후후..\\자네도 수없이 몬스터에게 당하면서 열심히 모험을 하다보면 나처럼 멋진 장비를 가질수 있을거야..\\음? 난 여기서 뭐하냐고?\\이 몸의 아까운 시간을 소비해 자네같은 초보 모험자들에게 멋진 모습을 보여주어 모험의욕을 자극하기 위해 있는거지..");
/// AddQuest(0x40000012, 0x0017, 1, 9, 4095, 0, "tAldia0101");

/// 알디아 NPC_08
SetNPC(1, 0x40000013, 0x10000001, false, "NPC_M06.GCMDS", "아카드");
SetPosition(0x40000013, 5.983, 2782.20, 24.27, 574.88);
SetNPCAttribute(0x40000013, 6, 1 );
AddPopup(0x40000013, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000013, "난 세상의 희귀한 물건들을 모으고 있지..");
AddDialog(0x40000013, 1, 0, "자네가 실력만 된다면, 자네가 날 위해 해줄일이 하나씩 쌓일거야.\\내가 자네에게 부탁할 일이 없다는 건 자네가 아직 애송이라는 뜻도 되지.");
/// AddQuest(0x40000013, 0x0018, 1, 9, 4095, 0, "tAldia0102");
