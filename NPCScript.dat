/// 감시자 대장장이
SetNPC(1, 0x40000076, 0x10000001, false, "NPC_H_blacksmith.GCMDS", "<대장장이>");
SetPosition(0x40000076, 0.923, 2138.21, 50.93, 2339.57);
SetNPCAttribute(0x40000076, 18, 1 );
AddPopup(0x40000076, 10000, 0, "대화하기", 0, 0 , 16715775);
AddPopup(0x40000076, 102, 31, "제련", 0, 40 , 16715775);
AddPopup(0x40000076, 379, 0, "옵션이식", 0, 20 , 16715775);
AddWords(0x40000076, "오..어서오게. 어떤 종류의 물건을 만들고 싶은가?");
AddDialog(0x40000076, 1, 0, "나는 무기와 갑옷,방패를 강화하는 작업을 하고있지.\\이는 매우 정밀한 작업이라 온도라던지 재료의 배합이라던지 하는 작업에서 약간의 오차만 있어도 실패한다네.\\하지만 늘 작품을 만든다는 생각으로 임하고 있다네.\\가끔 말도 못하게 피로가 쌓여 실패할때도 있지만 대부분의 고객은 만족하고 간다네.\\물론 성능이 좋은 아이템으로 개량할 수록 작업은 더욱더 어려워져서 궁극의 아이템을 만들기란 하늘의 별따기와 같다네.");
AddDialog(0x40000076, 2, 0, "강화하는법을 알려주지.\\먼저 강화할 아이템을 올려주게.\\각 단계별로 필요한 광물의 종류와 개수는 이렇다네.\\1단계: 실빈 3개\\2단계: 실빈 6개\\3단계: 실빈 9개\\4단계: 미스릴 3개\\5단계: 미스릴 6개\\6단계: 미스릴 9개\\7단계: 이터니움 3개\\8단계: 이터니움 6개\\9단계: 이터니움 9개\\아이템 강화란 더 좋은 아이템을 만들 수 있지만 실패 할 수도 있다네.");

/// 감시자 모험가트레이너
SetNPC(1, 0x40000077, 0x10000001, false, "NPC_M09.GCMDS", "<모험가 트레이너>");
SetPosition(0x40000077, 2.053, 2170.07, 51.31, 2328.34);
SetNPCAttribute(0x40000077, 16, 1 );
AddPopup(0x40000077, 10000, 0, "대화하기", 0, 0 , 16715775);
AddPopup(0x40000077, 223, 0, "스테이터스 재훈련", 0, 0 , 16715775);
AddPopup(0x40000077, 401, 31, "인간 공통 스킬북", 0, 0 , 16715775);
AddWords(0x40000077, "허허..어서 오게나. 어떤 기술이 적힌 스킬북이 필요한가?");
AddDialog(0x40000077, 1, 0, "내가 알려주는 기술들은 직업에 상관없이 모두\\사용할 수 있는 기술이라는 사실을 알고 있나?\\꼭, 자신의 직업기술만 익히지말고 여유가 된다면\\다른 직업의 기술도 익히는게 전투시에 유리하다\\네.");

