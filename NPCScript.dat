/// 감시자 퀘스트용 추가 캐릭터
SetNPC(1, 0x4000007E, 0x10000001, false, "NPC_M05.GCMDS", "헤롤드");
SetPosition(0x4000007E, 1.873, 2154.58, 50.84, 2370.95);
SetNPCAttribute(0x4000007E, 6, 1 );
AddPopup(0x4000007E, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000007E, "음.. 오늘은 어디로 사냥을 하러 갈까..");
AddDialog(0x4000007E, 1, 0, "이 주변에서 가장 큰 사냥장소는 오크요새지만, 그 이외에도 몇 군데 좋은 사냥터가 있습니다.\\뭐, 제가 알려드릴수도 있지만, 여기까지 올정도의 실력을 가진 모험자라면 스스로 찾아보십시오.");

SetNPC(1, 0x40000080, 0x10000001, false, "NPC_M11.GCMDS", "안내원");
SetPosition(0x40000080, 3.013, 2109.97, 50.95, 2372.75);
SetNPCAttribute(0x40000080, 6, 1 );
AddPopup(0x40000080, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000080, "어서 오십시오. 오크들을 감시하기 위해 세워진 캠프인 '감시자'에 오신걸 환영합니다.");
AddDialog(0x40000080, 1, 0, "전 그랜드코스트 지역의 동쪽캠프인 '감시자'의안내를 위해 왕국 관리소에서 파견된 공무원입니다.");

SetNPC(1, 0x40000081, 0x10000001, false, "NPC_M11.GCMDS", "안내원");
SetPosition(0x40000081, 5.646, 2169.42, 50.96, 2367.85);
SetNPCAttribute(0x40000081, 6, 1 );
AddPopup(0x40000081, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000081, "어서 오십시오. 오크들을 감시하기 위해 세워진 캠프인 '감시자'에 오신걸 환영합니다.");
AddDialog(0x40000081, 1, 0, "전 그랜드코스트 지역의 동쪽캠프인 '감시자'의안내를 위해 왕국 관리소에서 파견된 공무원입니다.");

SetNPC(1, 0x40000082, 0x10000001, false, "NPC_M10.GCMDS", "테너");
SetPosition(0x40000082, 2.413, 2112.65, 50.92, 2380.40);
SetNPCAttribute(0x40000082, 6, 1 );
AddPopup(0x40000082, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000082, "휴.. 물건이 떨어지기 전에 주문한 물품들이 무사히 도착해야 할텐데..");
AddDialog(0x40000082, 1, 0, "전 방어구상에서 일하는 종업원이죠.\\요즘 오크요새의 분위기가 심상치 않아 대규모로 물품을 주문하였죠.\\장사도 좋지만 매일 살얼음판을 걷는 기분이라 수명이 엄청나게 줄은 것 같아요.");

SetNPC(1, 0x40000084, 0x10000001, false, "NPC_M14.GCMDS", "경비대장 크루거");
SetPosition(0x40000084, 0.906, 2157.77, 51.98, 2322.13);
SetNPCAttribute(0x40000084, 6, 1 );
AddPopup(0x40000084, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000084, "으음.. 오크들을 자신 스스로의 본능에 충실하답니다.");
AddDialog(0x40000084, 1, 0, "오크들의 본능은 붉고 끈적한 피만이 연상되는 파괴와 살육이죠.");
/// AddQuest(0x40000084, 0x0108, 23, 26, 4095, 0, "nGamsiza2301");	//1차 추가 퀘스트

SetNPC(1, 0x40000085, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x40000085, 1.013, 2189.87, 52.34, 2348.57);
SetNPCAttribute(0x40000085, 6, 1 );
AddPopup(0x40000085, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000085, "그랜드코스트 동쪽지역 캠프인 '감시자'에 오신걸 환영합니다.");
AddDialog(0x40000085, 1, 0, "제 앞에 있는 언덕 넘어는 모두 오크들의 영역입니다.\\사냥을 하신다면 말리지는 않겠으나, 요새에는 수많은 오크들이 몰려있으니 요새내로 사냥을 가는 것은 자제를 해주십시오.");

SetNPC(1, 0x40000086, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x40000086, 2.233, 2162.97, 50.91, 2379.62);
SetNPCAttribute(0x40000086, 6, 1 );
AddPopup(0x40000086, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000086, "어서 오십시오. '감시자'캠프에 무사히 도착하셔서 다행입니다.");
AddDialog(0x40000086, 1, 0, "요즘 오크들이 갑자기 증가해서 이곳은 상당히 위험한 상태죠.\\여기까지 오신 모험자분께는 죄송하지만, 좀더 안전한 곳에서 사냥하실 것을 권하겠습니다.\\뭐, 그래도 사냥을 하시겠다면, 최대한 주의를 해주십시오.");

SetNPC(1, 0x40000087, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x40000087, 0.120, 2141.42, 54.35, 2402.40);
SetNPCAttribute(0x40000087, 6, 1 );
AddPopup(0x40000087, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000087, "여기는 오크를 감시를 목적으로 하는 '감시자'캠프입니다.");
AddDialog(0x40000087, 1, 0, "오크요새로 인해 요즘 이 주변지역에 대한 경계가 강화된 상태입니다.\\아직 사냥을 하실 수 있지만, 조심하시길 바랍니다.");

SetNPC(1, 0x40000088, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x40000088, 5.813, 2114.43, 50.92, 2358.74);
