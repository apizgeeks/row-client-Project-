SetNPC(4, 0x40003008, 0x10000001, false, "NPC_W02.GCMDS", "성직자트레이너");
SetPosition(0x40003008, 3.797, 2005.85, 10.00, 1057.43);
SetNPCAttribute(0x40003008, 16, 1 );
AddPopup(0x40003008, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x40003008, 104, 0, "전직하기", 0, 0 , 8);
AddPopup(0x40003008, 401, 35, "성직자 스킬북", 0, 0 , 16715775);
AddWords(0x40003008, "만나서 반갑습니다. 어떤 종류의 신앙서를 필요로 하십니까? ");
AddDialog(0x40003008, 1, 0, "전사에겐 강인한 체력이 마법사에겐 냉철한 지식이 도적에겐 바람과 같은 움직이 있다면 성직자에겐 흔들리지 않는 믿음의 마음이 있지요");
AddDialog(0x40003008, 2, 0, "만나서 반갑습니다. 신도님.\\신도님은 신앙심은 이제 여신님을 모시는\\한명의 신도로서 활동을 할 수 있을 정도가\\되었습니다.\\하지만 여신님을 따르는 진실되고 충실한\\신도가 되기 위해선 신도님께서 프리스트\\혹은 클래릭이라는 성직으로 신앙활동을\\해야합니다.\\그럼 신도님이 선택하실 두개의 성직에 대\\해 설명해 드리겠습니다.\\우선, 프리스트는 여신님의 축복이 담긴 성\\가를 찬송하며 악도를 물리치는 약간의 전\\투력을 가진 성직입니다.\\WIS와 CON을 주로 키우며 홀수레벨에선\\+2의 WIS와 +1의 CON가, 짝수레벨에선\\+1의 WIS와 +2의 CON가 자동으로 성장합\\니다.\\클래릭은 전투력은 거의 없지만 여신님께\\서 부여하신 강력한 치유력을 사용할 수 있\\는 성직입니다.\\역시, WIS와 CON을 키우지만 보다 높은\\신앙심을 발휘하기 위해 WIS를 중점적으로\\키우며 매 레벨마다 +2의 WIS와 +1의 CON\\이 자동으로 성장합니다.");

