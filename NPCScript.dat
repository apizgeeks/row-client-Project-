AddPopup(0x40000004, 223, 0, "스테이터스 재훈련", 0, 0 , 16715775);
AddPopup(0x40000004, 401, 31, "인간 공통 스킬북", 0, 0 , 16715775);
AddWords(0x40000004, "허허..어서 오게나. 어떤 기술이 적힌 스킬북이 필요한가?");
AddDialog(0x40000004, 1, 0, "내가 알려주는 기술들은 직업에 상관없이 모두 사용할 수 있다는 사실을 알고 있나?\\꼭, 자신의 직업기술만 익히지말고 여유가 된다면 다른 직업의 기술도 익히는게 전투시에 유리하다네.");
