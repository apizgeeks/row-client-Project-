/// 오페니 컴배턴트트레이너
SetNPC(2, 0x40001004, 0x10000001, false, "NPC_A_combat_t.GCMDS", "<컴배턴트 트레이너>");
SetPosition(0x40001004, 2.597, 2383.93, 30.85, 3290.92);
SetNPCAttribute(0x40001004, 16, 2 );
AddPopup(0x40001004, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x40001004, 104, 0, "전직하기", 0, 0 , 65536);
AddPopup(0x40001004, 401, 82, "컴배턴트 스킬북", 0, 0 , 16715775);
AddWords(0x40001004, "..반갑다. 어떤 전투지식이 필요한가?");
AddDialog(0x40001004, 1, 0, "기본적인 전투기술만이 아닌 전문적인 전투기술을 익히기 위해선 10LV의 성장을 통한 전직과 기술을 배우기 위한 댓가인 Gold가 필요하다.");
AddDialog(0x40001004, 2, 0, "어린 아칸이여 반갑다.\\귀관은 이제 한명의 성체로서 인정을 받을\\수 있는 자격을 가졌다.\\하지만 귀관이 확실한 성체로서 인정을 받\\으려면 특수한 형태로 진화를 해야만 한다.\\컴배턴트는 템플러, 어태커, 거너의 세 가\\지 형태로 진화를 할 수가 있다.\\템플러는 방어위주의 진화형태로서 막강한\\방어력을 가졌으며 추가로 약간의 신비한\\힘을 사용할 수 있다.\\홀수 레벨에서 +2의 STR과 +1의 CON이,\\짝수 레벨에선 +1의 STR과 +2의 CON이\\성장한다.\\어태커는 막강한 공격력을 가진 완전 공격\\위주의 진화형태로서, 매 레벨마다 +2의\\STR과 +1의 CON이 성장을 한다.\\거너는 먼거리의 적을 공격할 수 있는 장거\\리 공격위주의 진화형태로서, 약간의 전투\\보조에 관련된 신비한 힘을 사용하기도 한\\다.\\홀수레벨에선 +2의 DEX와 +1의 CON이,\\짝수레벨에선 +1의 DEX와 +2의 CON이 성\\장을 한다.");
