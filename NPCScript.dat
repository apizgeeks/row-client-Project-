SetNPC(1, 0x40000037, 0x10000001, false, "NPC_M11.GCMDS", "안내원");
SetPosition(0x40000037, 2.093, 2004.34, 65.84, 1429.26);
SetNPCAttribute(0x40000037, 6, 1 );
AddPopup(0x40000037, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000037, "만나서 반갑습니다. 여기는 악마의 대지를 감시하기 위해 세워진 '오래된 숲의 감시탑'입니다.");
AddDialog(0x40000037, 1, 0, "전 '오래된 숲의 감시탑'의 안내를 위해 왕국의 관리소에서 파견된 공무원입니다.");

SetNPC(1, 0x40000038, 0x10000001, false, "NPC_M04.GCMDS", "루미엘");
SetPosition(0x40000038, 1.557, 2020.87, 65.84, 1420.67);
SetNPCAttribute(0x40000038, 6, 1 );
AddPopup(0x40000038, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000038, "역시 악마의 대지에서 혼자 사냥을 하는 것은 무리인가..");
AddDialog(0x40000038, 1, 0, "같이 온 동료와 같이 사냥을 하다가 내가 상처를 입어 잠시 쉬는 중이야.\\같이 온 동료는 좀 더 안전하게 사냥을 하기위해 저 앞에서 같이 사냥할 파티원을 찾는 중이야.");

SetNPC(1, 0x40000039, 0x10000001, false, "NPC_M01.GCMDS", "케인");
SetPosition(0x40000039, 3.733, 2023.85, 65.87, 1442.38);
SetNPCAttribute(0x40000039, 6, 1 );
AddPopup(0x40000039, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000039, "흠.. 일단 벌목을 하기는 했는데 이 걸로 무엇을 할까..");
AddDialog(0x40000039, 1, 0, "강한 몬스터에게서 나오는 재료를 사용하면 원래보다 좀더 강력한 물건을 만들 수 있지.\\만약, 자네도 제련소에서 물건을 제작할 것이라면 이것을 기억하도록 하게나.");
/// AddQuest(0x40000039, 0x0107, 23, 26, 4095, 0, "nOldforest2301");	//1차 추가 퀘스트

SetNPC(1, 0x4000003A, 0x10000001, false, "NPC_M14.GCMDS", "카이");
SetPosition(0x4000003A, 2.127, 2046.56, 65.32, 1425.46);
SetNPCAttribute(0x4000003A, 6, 1 );
AddPopup(0x4000003A, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000003A, "실력있는 모험자들이 있어야 하는데, 어째 쓸만한 실력을 가진 모험자가 보이지 않는군.");
AddDialog(0x4000003A, 1, 0, "실력있는 모험자는 왜 찾느냐고?\\그야 당연히 부탁할 게 있어서지.\\어지간한 실력으론 어림도 없는 일이거든.\\만약, 자네가 실력에 자신이 있다면 '퀘스트'\\를 눌러보게나.");

SetNPC(1, 0x4000003B, 0x10000001, false, "NPC_M05.GCMDS", "조드");
SetPosition(0x4000003B, 3.613, 1982.34, 66.84, 1408.84);
SetNPCAttribute(0x4000003B, 6, 1 );
AddPopup(0x4000003B, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000003B, "쉿... 난 지금 몬스터들을 관찰하는 중이니 조용히 하게.");
AddDialog(0x4000003B, 1, 0, "난 왕국의 몬스터 조사기관에서 나온 조사관 이라네.\\이곳에서 오래된 숲에서 서식하는 많은 몬스터들의 생태와 습성등을 조사하는 중이지.\\우리가 조사한 정보는 안내원이라는 왕국의 공무원을 통해 자네들에게 알려지지.\\여기에도 안내원이 있으니 이 곳의 몬스터들에 관한 정보를 알고 싶으면, 그에게 물어보게.");

SetNPC(1, 0x4000003C, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x4000003C, 4.467, 1997.53, 65.83, 1410.05);
SetNPCAttribute(0x4000003C, 6, 1 );
AddPopup(0x4000003C, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000003C, "제 앞쪽에 있는 사람은 왕국의 몬스터조사관이라는데, 왠지 불안해서 지켜보는 중입니다.");
AddDialog(0x4000003C, 1, 0, "왕국 몬스터 조사기관은 우리 왕국이 이 대륙에서 살아가기위해 대륙전역에 퍼진 몬스터들에 관한 정보를 모아 보다 효과적으로 대처 하기위해 만들어진 곳입니다.\\저희와 안내원들이 알려드리는 정보는 모두 그들이 목숨을 걸고 조사한 것들이죠.");

SetNPC(1, 0x4000003D, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x4000003D, 2.947, 2033.87, 65.77, 1408.14);
SetNPCAttribute(0x4000003D, 6, 1 );
AddPopup(0x4000003D, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000003D, "어서 오십시오. 여기는 오래된 숲의 감시탑입니다.");
AddDialog(0x4000003D, 1, 0, "이 숲에는 고블린을 비롯해 대략 5종이상의 몬스터들이 서식하고 있죠.\\여기까지 오는동안 경험 하셨을지 모르지만, 숲이 워낙 어두워 몬스터가 잘 보이지 않으니 최대한 주의를 하시고 더욱 어두워지는 밤에는 가능한 사냥을 자제해 주십시오.");

SetNPC(1, 0x4000003E, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x4000003E, 3.954, 2040.30, 64.94, 1436.32);
SetNPCAttribute(0x4000003E, 6, 1 );
AddPopup(0x4000003E, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000003E, "오래된 숲의 감시탑에 오신 걸 환영합니다.");
AddDialog(0x4000003E, 1, 0, "원래 벌목장이었던 이곳은 위쪽의 분지에 건설되던 마을에 어떤 큰사건이 발생한 뒤로 벌목장을 폐쇠하고 현재는 '악마의 대지'라 불리는 그곳을 감시하기 위한 곳으로 바뀌게 되었습니다.");

SetNPC(1, 0x4000003F, 0x10000001, false, "NPC_M13.GCMDS", "캠프수비병");
SetPosition(0x4000003F, 2.177, 2001.63, 65.99, 1423.55);
SetNPCAttribute(0x4000003F, 6, 1 );
AddPopup(0x4000003F, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000003F, "여기는 악마의 대지를 감시하기위해 마련된 '오래된 숲의 감시탑'입니다.");
AddDialog(0x4000003F, 1, 0, "이 앞의 산길을 따라 계속 가면 나오는 분지가 '악마의 대지'입니다.\\원래는 '하이랜드'라는 마을을 건설하는 중 이었지만, 어떤 사건으로 폐허가 된채 버려지게 되었죠.\\사건당시의 생존자가 없어 어떤 일이 벌어 졌는지는 모르지만, 누군가 붙인 이곳의 지명으로부터 엄청난 존재가 나타났고, 그로인해 마을내의 주민이 모두 변을 당하지 않았나하고 왕국의 조사관들은 생각하는 것 같더군요.");
