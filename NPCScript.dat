SetNPC(1, 0x40000107, 0x10000001, false, "NPC_H_depositary.GCMDS", "<DragonTrans 센터>");
SetPosition(0x40000107, 0.310, 1930.68, 23.85, 1011.07);
SetNPCAttribute(0x40000107, 19, 1 );
AddPopup(0x40000107, 10000, 0, "대화하기", 0, 0 , 16715775);
AddPopup(0x40000107, 10000, 0, "설명듣기", 0, 0 , 16715775);
AddPopup(0x40000107, 107, 0, "물품보관함", 0, 0 , 16715775);
AddWords(0x40000107, "어서오십시오. DragonTrans 물류센터입니다.");
AddDialog(0x40000107, 1, 0, "우리 물류센터는 카르테란트 유일의 보관센터로서 최고의 안전성을 보장 한답니다.");
AddDialog(0x40000107, 2, 0, "보관소를 처음 사용하시면 보관함 한개는 무료로 이용하실 수 있구요.\\추가로 보관함을 이용하시려면 '사용불가' 탭을 클릭하시면 보관함을 추가로 구입할 수 있어요.\\ \\또한 저희는 물건을 맡길 때마다 수수료를 받고 있답니다.\\맡길 물건은 신중히 선택해 주세요.\\ \\ 비밀번호는 저장해 두시고 사용할 수 있지만 물건을 분실했을 경우 본사는 책임지지 않사오니 비밀번호를 잘 관리 해주시기 바랍니다.\\ \\비밀번호를 분실했을때에는 홈페이지로  문의해주시기 바랍니다.");


