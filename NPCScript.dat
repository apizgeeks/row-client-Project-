// "생명제사 사당의 포아"
SetNPC(12, 0x40012033, 0x10000001, false, "NPC_A_Guide_a.GCMDS", "포아\\<생명력 흡수 기계 관리자>");
SetPosition(0x40012033, 4.654, 3190.92, 137.08, 3501.60);
SetNPCAttribute(0x40012033, 6, 0 );
AddPopup(0x40012033, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x40012033, "제 뒤에 있는 장치가 바로 생명력 흡수 기계에요.");
AddDialog(0x40012033, 1, 0, "이미 알고 계시겠지만, 아칸의 생명력은 대지로 부터 얻어지는 것이에요.\\인간이 대지로 부터 영양을 얻는 것과 다를 것이 없죠.\\다만 아칸은 가공되지 않은 대지의 힘을 곧바로 이용해요.\\간혹 장치에 이상이 생기면 이 기계는 되려 근처 생물들의 생명력을 흡수해 버리니 조심하세요.");


// "배릭마을의 왕 바락"
SetNPC(12, 0x40012034, 0x10000001, false, "Mon_Barick.GCMDS", "바락\\<배릭종족의 왕>");
SetPosition(0x40012034, 3.407, 2879.93, 90.69, 3577.34);
SetNPCAttribute(0x40012034, 6, 0 );
AddPopup(0x40012034, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x40012034, "두발로 걷는 놈들중에 산채로 나에게 볼일이 있는 녀석들은 별로 없지. 혹시 배릭킹의 감미료가 필요한가?");
AddDialog(0x40012034, 1, 0, "배릭은 거짓말은 해도 약속을 어기는 일은 없지.\\단 배릭과의 약속을 어기게 되면 고통의 마지막 메아리가 울릴 때까지 괴롭혀 주지. 절대 먹진 않아. 두발달린 녀석들의 고기는 질기거든.");


