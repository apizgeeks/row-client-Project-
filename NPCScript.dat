AddWords(0x40001063, "반전단체 Peace.Of.World 에 오신걸 환영하오.");
AddDialog(0x40001063, 1, 0, "사실 이 대륙의 전쟁은 막기 힘든 현실이오.\\우리 반전단체의 힘으로 막을수 있을런지..\\하지만 우리의 신념은 변치 않소.\\평화를 사랑하는 사람들을 지켜야만 하오.\\적과 아군이 아닌 이 대륙의 공존자로서 말이오.");

SetNPC(2, 0x40001005, 0x10000001, false, "NPC_A_guardian_soldier.GCMDS", "경비병");
SetPosition(0x40001005, 4.927, 2309.43, 30.85, 3248.62);
SetNPCAttribute(0x40001005, 6, 2 );
AddPopup(0x40001005, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40001005, "어서 오십시오. 오페니에 오신 걸 환영합니다.");
AddDialog(0x40001005, 1, 0, "어느 정도 성장할때까지 이 주변에서 살고있는 몬스터를 사냥하면서 수련을 하십시오.\\이 마을의 주변에 있는 몬스터는 전 수련지역에서 가장 약한 몬스터들이 있는 곳이니 가벼운 마음으로 조금씩 사냥의 감각을 익히십시오.");
/// AddQuest(0x40001005, 0x0027, 1, 9, 16711680, 0, "tOpe0103");

SetNPC(2, 0x40001006, 0x10000001, false, "NPC_A_guardian_soldier.GCMDS", "경비병");
SetPosition(0x40001006, 0.073, 2441.17, 31.10, 3205.57);
SetNPCAttribute(0x40001006, 6, 2 );
AddPopup(0x40001006, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40001006, "어서 오십시오. 오페니에 오신 걸 환영합니다.");
AddDialog(0x40001006, 1, 0, "마을 이외의 장소에는 몬스터들이 상당히 돌아다니니 마을밖으로 나갈때는 충분한 준비를 하십시오.\\여기가 아무리 비기너들을 위한 수련지역이라서 몬스터들이 약하다지만, 몬스터라 불리는 생명체가 위험하다는 것은 변함이 없으니까요.");
/// AddQuest(0x40001006, 0x0015, 5, 10, 16711680, 0, "nOpe0502");

SetNPC(2, 0x40001007, 0x10000001, false, "NPC_A_guardian_soldier.GCMDS", "경비병");
SetPosition(0x40001007, 0.221, 2404.64, 30.00, 3271.52);
SetNPCAttribute(0x40001007, 6, 2 );
AddPopup(0x40001007, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40001007, "어서 오십시오. 오페니에 오신 걸 환영합니다.");
AddDialog(0x40001007, 1, 0, "왕도에서 이곳으로 오는 것은 쉽지만, 돌아가는 것은 왕도로 가는 길을 통해서만 갈 수 있습니다.\\왕도로 돌아가고 싶다면 열심히 수련을 해서 스스로의 힘으로 돌아가십시오.\\그것이 이곳을 수련지역으로 택한 이유니까요.");
