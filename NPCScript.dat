/// 테시티오 길드관리대표
SetNPC(1, 0x40000100, 0x10000001, false, "NPC_M11.GCMDS", "<길드관리대표>");
SetPosition(0x40000100, 3.131, 1428.21, 9.91, 2017.49);
SetNPCAttribute(0x40000100, 28, 1 );
AddPopup(0x40000100, 10000, 0, "설명듣기", 0, 0 , 16715775);
AddPopup(0x40000100, 222, 0, "길드만들기", 0, 0 , 16715775);
AddWords(0x40000100, "삶에선 잃지 말아야 할 여러가지가 있지만, 그중 하나는 자신 주변의 소중한 사람들이랍니다.");
AddDialog(0x40000100, 1, 0, "●길드가입신청은 화면의 우하단 [길드]메\\ 뉴에서 가능합니다.\\●길드를 창단하려면 1000000(백만)Gold의\\ 화폐가 필요하며, 30LV 이상 되어야 합니\\ 다.\\\\\\●길드를 확장할때는 다음과 같은 조건\\을 만족시켜야 합니다.\\======================================\\  길드 명성치와 확장 가능 인원 제한 값\\--------------------------------------\\  필요명성치 | 제한인원 |    필요금액\\--------------------------------------\\             0   |     10     |   1,000,000\\        2000   |     20     |   5,000,000\\       10000   |     30     |  10,000,000\\       25000   |     40     |  50,000,000\\       50000   |     50     | 100,000,000\\======================================\\");

