// "고대인 나무아래 이야기 나누고 있는 1"
SetNPC(12, 0x40012113, 0x10000001, false, "NPC_Quest_OldAncient.GCMDS", "빌마르윈\\<고대인의 후예>");
SetPosition(0x40012113, 2.644, 789.16, 159.7, 873.82);
SetNPCAttribute(0x40012113, 6, 0 );
AddPopup(0x40012113, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x40012113, "반가워요.");
AddDialog(0x40012113, 1, 0, "보시는 바와 같이 이곳의 주변은 검게 물들어 가고 있습니다.\\모두 [절대악]의 존재인 [벨제뷔트]의 힘이 커지면서 생겨난 일이예요.\\쉽게 말하자면 이곳은 어둠에 의해 먹혀지고 있죠.");


// "고대인 나무아래 이야기 나누고 있는2"
SetNPC(12, 0x40012114, 0x10000001, false, "NPC_Quest_Ancient.GCMDS", "티라스\\<고대인의 후예>");
SetPosition(0x40012114, 0.068, 789.91, 160.01, 872.32);
SetNPCAttribute(0x40012114, 6, 0 );
AddPopup(0x40012114, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x40012114, "건강하신가요?");
AddDialog(0x40012114, 1, 0, "[벨제뷔트]는 우리들의 선조인 [고대인]들이 발명한 [차원의 문]을 이용해 이곳의 차원으로 넘어오려고 한다더군요.\\전 [차원의 문]전공이 아니라 자세히는 모르겠습니다.\\[거대 고목]의 [바레하]는 모든 학문의 전공 과정을 끝냈으니 보다 잘 설명할 수 있을지도 모르겠습니다.");


// "고대인"
SetNPC(12, 0x40012115, 0x10000001, false, "NPC_Quest_OldAncient.GCMDS", "바레하\\<고대인의 후예>");
