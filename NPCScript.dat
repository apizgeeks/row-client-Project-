// "얼어붙은 초원 집앞 방어구 상인"
SetNPC(12, 0x40012085, 0x10000001, false, "NPC_SnowMan.GCMDS", "아디아르\\<스노우림프족 방어구상인>");
SetPosition(0x40012085, 2.618, 1130.70, 151.95, 2898.73);
SetNPCAttribute(0x40012085, 14, 0 );
AddPopup(0x40012085, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x40012085, 401, 12, "인간 방어구상점", 0, 0 , 16715775);
AddPopup(0x40012085, 401, 62, "아칸 방어구상점", 0, 0 , 16715775);
AddWords(0x40012085, "외부인 이군요..혹시 필요한 방어구가 있는가 보시겠어요?");
AddDialog(0x40012085, 1, 0, "이곳 [쉬림프]들의 주거지인 [엘리오르]는 한때 [세비지 포쳐]의 공격을 자주 받곤 해서 [롱기어족 상인]의 도움을 받아 무구들을 잔뜩 구입해 두었는데..\\지금은 모험가들 때문인지 [세비지 포쳐]들의 횡포가 줄어들게 되었지요..\\그래서 이젠 [스노우림프]에겐 쓸모가 없어진 장비들을 팔기로 결정했답니다.");

