//바르윈 물품보관소
SetNPC(5, 0x40004006, 0x10000001, false, "NPC_A_depositary.GCMDS", "DragonTrans 센터");
SetPosition(0x40004006, 5.963, 3083.19, 102.56, 863.37 );
SetNPCAttribute(0x40004006, 19, 2 );
AddPopup(0x40004006, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x40004006, 10000, 0, "설명듣기", 0, 0 , 16715775);
AddPopup(0x40004006, 107, 0, "물품보관함", 0, 0 , 16715775);
AddWords(0x40004006, "어서오십시오. DragonTrans 물류센터입니다.");
AddDialog(0x40004006, 1, 0, "그대와 같이 강한 전사들은 많은 물건들을 보관할 필요가 있지않소?\\음...하지만 1인당 보관함은 4개밖에 대여해주지 않는다오.\\귀한 물건만 보관하는게 낫소.\\워낙 가진게 없다면 아무거나 넣어도 상관은 없소만..");                          
AddDialog(0x40004006, 2, 0, "보관소를 처음 사용하시면 보관함 한개는 무료로 이용하실 수 있습니다.\\추가로 보관함을 이용하시려면 '사용불가'탭을 클릭하시면 보관함을 추가로 구입할 수 있습니다.\\ \\또한 저희는 물건을 맡길때마다 수수료를 받고 있습니다.\\맡길 물건은 신중히 선택해 주십시오.\\ \\비밀번호는 저장해 두시고 사용할 수 있지만 물건을 분실했을 경우 본사는 책임지지 않사오니 비밀번호를 잘 관리 해주시기 바랍니다.\\ \\비밀번호를 분실했을때에는 홈페이지로 문의해주시기 바랍니다.");

