SetNPC(1, 0x40000014, 0x10000001, false, "NPC_M12.GCMDS", "경비병");
SetPosition(0x40000014, 5.487, 2721.10, 24.21, 577.74);
SetNPCAttribute(0x40000014, 6, 1 );
AddPopup(0x40000014, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000014, "어서 오십시오. 알디아 항구에 오신 걸 환영합니다.");
AddDialog(0x40000014, 1, 0, "보아하니 초보 모험자인 것 같군요.\\그렇다면 어느정도 성장하기 전까진 이 앞의 모래사장에 돌아다니는 '씨맨'이라고 불리는 뚱뚱한 물고기처럼 생긴 몬스터를 사냥하세요.\\워낙 약해 이 주변에선 그나마 안심하고 사냥을할 수 있는 몬스터죠.");

SetNPC(1, 0x40000015, 0x10000001, false, "NPC_M12.GCMDS", "경비병");
SetPosition(0x40000015, 1.763, 2728.87, 25.08, 649.89);
SetNPCAttribute(0x40000015, 6, 1 );
AddPopup(0x40000015, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000015, "여기는 왕국 최전방 개척지 그랜드코스트지역의 알디아 항구입니다.");
AddDialog(0x40000015, 1, 0, "마을 이외의 장소에는 몬스터들이 상당히 돌아다니니 마을밖으로 나갈때는 충분한 준비를 하십시오.\\아무리 저희 왕국군이 이 지역을 장악했다 하더라도 끈임없이 나타나는 몬스터를 모두 처리할 수 없으니까요.\\게다가 수도쪽에 큰일이 벌어져 이쪽으론 왕국군을 보낼 여력이 없다고 하더군요.");

SetNPC(1, 0x40000016, 0x10000001, false, "NPC_M12.GCMDS", "경비병");
SetPosition(0x40000016, 2.257, 2785.34, 21.39, 701.05);
SetNPCAttribute(0x40000016, 6, 1 );
AddPopup(0x40000016, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000016, "반갑습니다. 이곳은 그랜드코스트 지역의 유일한 항구인 알디아 항구입니다.");
AddDialog(0x40000016, 1, 0, "수도에서 이 곳으로 오는 이동로는 몇 개가 존재하지만, 배를 이용해서 오는 것이 가장 안전하면서 빠른 이동로죠.\\그래서 이 지역으로 오는 물자는 대부분 배를 이용해 가져오죠.");

SetNPC(1, 0x40000017, 0x10000001, false, "NPC_M12.GCMDS", "경비병");
SetPosition(0x40000017, 3.867, 2699.06, 21.68, 757.14);
SetNPCAttribute(0x40000017, 6, 1 );
AddPopup(0x40000017, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000017, "어서 오십시오. 알디아 항구에 오신 걸 환영합니다.");
AddDialog(0x40000017, 1, 0, "이 앞쪽의 해안에 나타나는 '라폰'이라는 가제를 닮은 몬스터는 초보 모험자들에겐 사신과도 같은 존재입니다.\\언젠가 겁없는 모험자 몇이 멋모르고 덤볐다가 혼줄이 난 적이 있었죠.\\당신도 실력이 되지 않는다면, 그 근처론 가지마십시오.\\뭐, 굳이 저 하늘의 별이 되고싶다면 말리지는 않겠습니다만..");

