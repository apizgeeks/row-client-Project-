SetNPCAttribute(0x40012115, 6, 0 );
AddPopup(0x40012115, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x40012115, "세상의 모든 지식들은 끊임없이 태어나지만 세상의 모든 생명은 끊임 없이 사라지지요.");
AddDialog(0x40012115, 1, 0, "세상의 모든 일을 알 수 있다면 무모한 도전은 일어나지 않지요.\\[고대인의 후예]들은 많은 지식을 얻게된 반면에..\\무모함을 잃었답니다.");

