//뉴베린 대장장이
SetNPC(4, 0x40003003, 0x10000001, false, "NPC_H_blacksmith.GCMDS", "<대장장이>");
SetPosition(0x40003003, 5.786, 1949.78, 10.00, 1024.42);
SetNPCAttribute(0x40003003, 18, 1 );
AddPopup(0x40003003, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x40003003, 102, 31, "제련", 0, 40 , 16715775);
AddPopup(0x40003003, 379, 0, "옵션이식", 0, 20 , 16715775);
AddWords(0x40003003, "오.. 어서오게. 그래 어떤 물건을 만들고 싶은가?");
AddDialog(0x40003003, 1, 0, "나는 무기와 갑옷,방패를 강화하는 작업을 하고있지. \\이는 매우 정밀한 작업이라 온도라던지 재료의 배합이라던지 하는 작업에서 약간의 오차만 있어도 실패한다네. \\가끔 말도 못하게 피로가 쌓여 실패할때도 있지만 대부분의 고객은 만족하고 간다네.\\물론 성능이 좋은 아이템으로 개량할 수록 작업은 더욱 더 어려워지지만......");
AddDialog(0x40003003, 2, 0, "[제련에 관한 이야기]\\                                       \\제련은 [갑옷/무기/스킬암/방패] 타입에 해당하는 장비품을 강화시키는 작업을 말합니다.\\위의 장비품을 제련하기 위해선 특별한 광물 [실빈/미스릴/이터늄]등을 필요로 합니다.\\광물은 종류에 상관없이 1회의 제련시 마다 10개가 소모되며 각 광물은 [실빈<미스릴<이터늄]의 순으로 제련시 성공 확률이 높습니다.\\제련에 실패했을 경우 50%의 확률로 해당 장비품의 제련수치가 -1이 되며 소켓에 넣어진 보석이 사라지게 되니 주의하십시오.\\                                       \\                                       \\[옵션이식에 관한 이야기]\\                                       \\옵션 이식은 장비품이 지니고 있는 옵션을 다른 장비품의 옵션과 함하여 평균값을 취하게 만드는 것을 의미합니다.\\옵션이식은 [갑옷/무기/스킬암/방패] 타입의 장품만 가능하며 옵션을 받게될 [대상]이 되는 장비와 옵션을 줄 [제물]이 되는 장비가 필요합니다.\\옵션 이식은 실패할 확률이 없으며 옵션 이식을 끝냈을 경우 해당 장비품의 제련에 의한 수치와 소켓에 넣어진 보석에 의한 수치는 그대로 남아있게 됩니다.");

