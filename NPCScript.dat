SetNPC(1, 0x4000005A, 0x10000001, false, "NPC_M04.GCMDS", "파이커");
SetPosition(0x4000005A, 0.626, 1334.67, 17.11, 1989.42);
SetNPCAttribute(0x4000005A, 6, 1 );
AddPopup(0x4000005A, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000005A, "만나서 반갑네. 난 지금 길드를 찾는 모험자중에서 동료로 삼을만한 사람을 찾는 중이지.");
AddDialog(0x4000005A, 1, 0, "이 건물은 이 지역에서 활동하는 모든 모험자들을 관리하는 곳이라 많은 모험자들이 오가는 곳입니다.\\특히, 전사들이 주로 오가기에 성직자인 저와 같이 파티를 이룰 전사을 찾기엔 가장 좋은 장소입니다.");

SetNPC(1, 0x4000005C, 0x10000001, false, "NPC_W05.GCMDS", "소니아");
SetPosition(0x4000005C, 1.906, 1406.21, 11.04, 2116.52);
SetNPCAttribute(0x4000005C, 6, 1 );
AddPopup(0x4000005C, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000005C, "북쪽에 보이는 저 탑을 볼때마다 느끼는 것이지만 정말 놀랍다고 생각하지 않아요?");
AddDialog(0x4000005C, 1, 0, "저 거대한 탑은 '이란샤의 탑'이라 불리죠.\\제가 들은 이야기에 의하면, 저탑은 아주 오래전에 이 대륙에 아주 뛰어난 문명이 있었던 시대에 지어졌던 것이라고 하더군요.\\솔직히 좀 믿기지 않는 이야기지만, 눈 앞에 증거가 있으니 않믿기도 힘들고..\\이전에 존재하였던 문명이 어떤 것인지 궁금하다고 생각되지 않나요?");

SetNPC(1, 0x4000005D, 0x10000001, false, "NPC_M08.GCMDS", "케이든");
SetPosition(0x4000005D, 4.883, 1425.90, 10.85, 2089.14);
SetNPCAttribute(0x4000005D, 6, 1 );
AddPopup(0x4000005D, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000005D, "마을밖으로 나갈 생각이라면 위험한 몬스터들이 아주 많으니 조심하세요.");
AddDialog(0x4000005D, 1, 0, "북쪽에는 상당히 무슨 이유인지 몰라도 상당히 강력한 몬스터들이 많이 살고있죠.\\실력이 안된다면, 갈 생각은 하지마세요.");
/// AddQuest(0x4000005D, 0x0008, 5, 10, 4095, 0, "nTesitio0503");

SetNPC(1, 0x4000005E, 0x10000001, false, "NPC_W03.GCMDS", "실비아");
SetPosition(0x4000005E, 5.433, 1484.73, 10.85, 2079.12);
SetNPCAttribute(0x4000005E, 6, 1 );
AddPopup(0x4000005E, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000005E, "음..미안하지만, 난 지금 집안일을 해야하니 방해말아 주시겠어요?");
AddDialog(0x4000005E, 1, 0, "제가 한가지 정보를 알려드릴테니 방해하지 말아요.\\이쪽 출구로 나가 길을 따라 쭉 가다보면 넓은 분지위에 세워진 거대한 요새를 볼 수 있죠.\\요즘 수많은 오크들이 돌아다니고 있다고 하니, 호기심이 생기면 한번 가보도록 하세요.\\자, 이제 전 일을 해야하니 방해하지 말아주세요.");

SetNPC(1, 0x4000005F, 0x10000001, false, "NPC_W06.GCMDS", "로니아");
SetPosition(0x4000005F, 5.957, 1513.56, 10.93, 2063.38);
SetNPCAttribute(0x4000005F, 6, 1 );
AddPopup(0x4000005F, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000005F, "당신도 모험자군요. 전 고르곤이라는 몬스터의 사냥을 하기위해 잠시 쉬는 중이랍니다.");
AddDialog(0x4000005F, 1, 0, "고른곤은 소의 형태를 하고 있는 몬스터로서 아주 강한 몬스터의 하나죠.\\고르곤이 나타나는 곳은 도시의 서쪽 언덕 위랍니다.");

SetNPC(1, 0x40000060, 0x10000001, false, "NPC_W03.GCMDS", "티아라");
SetPosition(0x40000060, 0.017, 1491.72, 8.99, 1979.22);
SetNPCAttribute(0x40000060, 6, 1 );
AddPopup(0x40000060, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000060, "매일 밤마다 길 건너편에 있는 작은 공터에 사람들이 모이는 것 같은데 이유가 뭘까요?");
AddDialog(0x40000060, 1, 0, "마을 내의 작은 공터엔 매일 밤마다 모험자들이 모이는 것 같더군요.\\이유는 모르겠지만, 하루도 빠짐없이 모이더군요.");

SetNPC(1, 0x40000061, 0x10000001, false, "NPC_M04.GCMDS", "로이드");
SetPosition(0x40000061, 2.313, 1350.62, 22.35, 2080.97);
SetNPCAttribute(0x40000061, 6, 1 );
AddPopup(0x40000061, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000061, "어서 오십시오. 이 곳은 빛과 정의의 여신님을 모시는 성소입니다.");
AddDialog(0x40000061, 1, 0, "여기는 이 지역의 성직활동을 하시는 분들을 위해 마련된 빛과 정의의 여신이신 '아일피아스' 님을 모시는 성소입니다.\\총본산은 수도인 '에스피오른'에 존재하며 왕국에서 활동하는 성직자분들은 모두 저희 '아일피아스 교단'의 신도들이시죠.");

SetNPC(1, 0x40000062, 0x10000001, false, "NPC_M10.GCMDS", "보우거");
SetPosition(0x40000062, 4.573, 1463.64, 8.85, 1920.15);
SetNPCAttribute(0x40000062, 6, 1 );
AddPopup(0x40000062, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000062, "허허..만나서 반갑네. 역시 젊은 모험자를 본다는 것은 즐거운 일이야..");
AddDialog(0x40000062, 1, 0, "난 이곳이 개척부대에 의해 왕국으로 편입이 된 후, 이곳을 개발하러 온 사람들 중에 하나였지 내가 수도로 돌아가지 않고 이곳에 남은 것은 나의 손길이 묻어있는 이곳이 어떻게 변해가는지 보고싶어서라네.\\자네와 같은 모험가들로인해 점점 활기차가는 이곳을 보노라면 뿌듯한 보람과 즐거움을 느낄 수 있지.");

SetNPC(1, 0x40000063, 0x10000001, false, "NPC_W03.GCMDS", "이베니아");
SetPosition(0x40000063, 4.663, 1544.43, 17.42, 2019.48);
SetNPCAttribute(0x40000063, 6, 1 );
AddPopup(0x40000063, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000063, "아. 혹시 남편이 어디에 있는지 알고 있나요?");
AddDialog(0x40000063, 1, 0, "하루종일 남편이 보이지 않아서 걱정이네요. 저에게 매일 재미난 이야기를 해주어 즐겁지만, 가끔 하루 종일 보이지 않을때가 있어서 걱정이 되네요.\\즐거운 이야기도 좋지만 저에게 어디간다는 이야기만이라도 해주었으면 하는데.");

SetNPC(1, 0x40000065, 0x10000001, false, "NPC_M05.GCMDS", "토니");
SetPosition(0x40000065, 0.157, 1395.68, 9.37, 1957.12);
SetNPCAttribute(0x40000065, 6, 1 );
AddPopup(0x40000065, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000065, "테시티오는 넓은 곳인만큼 사람도 많지요. 그중 몇몇은 꼭 만나는게 좋답니다. 특히 마을 남동쪽 외곽에 있는 [키스케]같은 경우는 말이죠.");
AddDialog(0x40000065, 1, 0, "메르카디아와의 전투는 매우 위험하지요?\\저도 가보고 싶지만 이곳을 관리하는 저로서는 전투를 치르고 돌아오시는 분들의 이야기를 듣는것도 재밌습니다.");

SetNPC(1, 0x40000066, 0x10000001, false, "NPC_W04.GCMDS", "엘리");
SetPosition(0x40000066, 2.077, 1345.06, 18.25, 2053.41);
SetNPCAttribute(0x40000066, 6, 1 );
AddPopup(0x40000066, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000066, "안녕하세요. 당신도 이 지역에 모험을 하러 온 사람인가 보네요.");
AddDialog(0x40000066, 1, 0, "이 도시의 주변에는 모험하기 좋은 장소가 2군데 존재하죠.\\도시 서쪽의 평야 끝에 있는 유적과 도시 북쪽에 보이는 탑인데, 모험자들의 이야기로는 어지간한 실력과 동료들의 도움이 없다면 모험하기 힘든 곳이라고 하더군요");

SetNPC(1, 0x40000067, 0x10000001, false, "NPC_M12.GCMDS", "마을경비병");
SetPosition(0x40000067, 2.943, 1301.01, 12.85, 2030.90);
SetNPCAttribute(0x40000067, 6, 1 );
AddPopup(0x40000067, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000067, "어서 오십시오. 여기는 이 지역의 중앙마을인 테시티오라고 합니다.");
AddDialog(0x40000067, 1, 0, "이 길을 따라가면 우리가 서부평야라 부르는 곳이 나오는데, 그 곳에는 트롤을 비롯하여 트라이벌이라 불리는 아주 강한 몬스터들이 돌아다닙니다.");

SetNPC(1, 0x40000068, 0x10000001, false, "NPC_M12.GCMDS", "마을경비병");
SetPosition(0x40000068, 4.747, 1414.64, 13.92, 2142.96);
SetNPCAttribute(0x40000068, 6, 1 );
AddPopup(0x40000068, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000068, "여기는 그랜드코스트 지역의 중앙도시인 테시티오입니다.");
AddDialog(0x40000068, 1, 0, "이 북부지역은 그랜드코스트지역을 통틀어 가장 강한 몬스터들이 서식하고 있습니다.\\'이란샤의 탑'의 영향때문에 그런것이 아닌가 하는 추측을 합니다만, 사실이야 어째든, 이곳에서 사냥을 하시겠다면, 철저하게 준비를 하고 사냥에 나가시도록 하십시오.\\아, 그리고 마을 밖을 나가자마자 왼쪽 언덕위에 투기장이 있으니 관심이 있으시면, 한번 가보도록 하십시오.");

SetNPC(1, 0x40000069, 0x10000001, false, "NPC_M12.GCMDS", "마을경비병");
SetPosition(0x40000069, 5.147, 1495.36, 13.58, 2119.51);
SetNPCAttribute(0x40000069, 6, 1 );
AddPopup(0x40000069, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000069, "어서 오십시오. 테시티오에 오신걸 환영합니다.");
AddDialog(0x40000069, 1, 0, "이 통로로 나가시면 저희가 동부평야라 부르는 곳입니다.\\동부평야는 이 주변에서 그나마 사냥하기 쉬운곳으로 길을 따라가면, 동쪽캠프인 '감시자' 와 '오크요새' 에 도착할 수 있습니다.\\아, 한가지. 황무지 근처에 '캐리언크로울러' 라 불리는 몬스터가 돌아다니니 조심하십시오.");

SetNPC(1, 0x4000006A, 0x10000001, false, "NPC_M12.GCMDS", "마을경비병");
SetPosition(0x4000006A, 4.747, 1446.21, 9.63, 1905.69);
SetNPCAttribute(0x4000006A, 6, 1 );
AddPopup(0x4000006A, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000006A, "어서 오십시오. 무사히 테시티오에 도착해 다행입니다.");
AddDialog(0x4000006A, 1, 0, "여기까지 혼자의 힘으로 왔다면 저희가 남부평야라 불리는 이 곳엔 여러분이 크게 조심 해야할 몬스터는 없다고 생각하시면 됩니다.\\하지만, 남부평야의 서쪽에 존재하는 커다란 숲, 저희들이 '테시티오 남쪽 숲'이라부르는 그 숲은 서쪽평야와 연결되어 있어 강한 몬스터들이 대거 서식하고 있습니다.\\만약, 그곳에서 사냥을 하겠다면, 대단히 주의해서 사냥해주십시오.");

