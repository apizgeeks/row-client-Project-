/// 첫번째 휴식 마법사트레이너
SetNPC(1, 0x40000024, 0x10000001, false, "NPC_M06.GCMDS", "<마법사 트레이너>");
SetPosition(0x40000024, 0.863, 1917.19, 24.78, 972.54);
SetNPCAttribute(0x40000024, 16, 1 );
AddPopup(0x40000024, 10000, 0, "대화하기", 0, 0 , 16715775);
AddPopup(0x40000024, 104, 0, "전직하기", 0, 0 , 4);
AddPopup(0x40000024, 401, 34, "마법사 스킬북", 0, 0 , 16715775);
AddWords(0x40000024, "반갑습니다. 어떤 종류의 마법서를 필요로 하십니까?");
AddDialog(0x40000024, 1, 0, "우리의 몸은 일반인과 다를바 없으나 정신만큼은 누구도 따라올 수 없답니다.");
AddDialog(0x40000024, 2, 0, "마법이라는 끝없는 학문을 추구하는 동지\\여 만나서 반갑습니다.\\당신은 이제 한 사람의 마법사로 불리기에\\부족함이 없을 정도의 마법이라는 학문을\\깨달은 것 같군요.\\하지만 당신이 마법사 길드의 일원으로 승\\인받고 진정한 왕국의 마법사로 불리기 위\\해선 소서러나 엔찬터라는 직업에 해당하\\는 새로운 마법을 배우지 않으면 안됩니다.\\일단, 당신이 어떤 것을 배울지 선택하는데\\도움이 되도록 두개의 직업에 대해 설명을\\해드리겠습니다.\\먼저, 소서러는 아주 강력한 위력을 발휘\\하는 공격마법을 사용하는 전투에서 가장\\화려한 클래스입니다.\\INT와 DEX를 주로 키우지만 마법의 위력\\을 강하게 하는 INT를 중점적으로 키우는\\클래스입니다.\\매 레벨마다 +2의 INT와 +1의 DEX가 자동\\으로 성장합니다.\\다음으로 엔찬터는 화려하지 않지만 전투\\에 큰도움을 주는 강력한 보조마법을 사용\\하는 클래스입니다.\\INT와 DEX를 주로 키우며, 홀수레벨에선\\+2의 INT와 +1의 DEX가, 짝수 레벨에선\\+1의 INT와 +2의 DEX가 자동으로 성장합\\니다.");

