AddPopup(0x4000008F, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000008F, "음..이 지역도 거의 다 돌아다녔는데, 이젠 어떻할까…");
AddDialog(0x4000008F, 1, 0, "전 이 곳이 처음 개발될때부터 이 지역을 모험하기 시작하였죠.\\수행을 쌓고 반드시 카나번까지 도달해서 아칸들과 맞설 거에요.");
/// AddQuest(0x4000008F, 0x0114, 35, 89, 4095, 0x0113, "nGate3501"); // 1차 추가 퀘스트

SetNPC(1, 0x40000090, 0x10000001, false, "NPC_M13.GCMDS", "그랜트");
SetPosition(0x40000090, 0.737, 586.14, 154.34, 2668.21);
SetNPCAttribute(0x40000090, 6, 1 );
AddPopup(0x40000090, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000090, "어서 오십시오. 여기는 '관문소'입니다.");
AddDialog(0x40000090, 1, 0, "이 앞쪽에는 그랜드코스트 지역에서 가장 강한 몬스터들이 주로 돌아다니고 있습니다.\\물론, 여기까지 오셨으니 뛰어난 실력을 가지셨겠지만, 모험자에겐 방심은 곧 죽음과 직결되니 조심하십시오.");

SetNPC(1, 0x40000091, 0x10000001, false, "NPC_M13.GCMDS", "케로스");
SetPosition(0x40000091, 2.297, 599.06, 153.85, 2677.05);
SetNPCAttribute(0x40000091, 6, 1 );
AddPopup(0x40000091, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000091, "지역경계를 관리하는 '관문소'에 오시걸 환영합니다.");
AddDialog(0x40000091, 1, 0, "이 안쪽으로 계속가면 그랜드코스트 지역을 벗어나 왕국의 수도가 존재하는 지역으로 가실수 있습니다.");

/////////////////////////////////////////////////////////////////////////////////////
/////////////						몬스터조사관						/////////////
/////////////////////////////////////////////////////////////////////////////////////

SetNPC(1, 0x40000092, 0x10000001, false, "NPC_M11.GCMDS", "가이너");
SetPosition(0x40000092, 2.210, 1461.21, 180.85, 3017.73);
SetNPCAttribute(0x40000092, 6, 1 );
AddPopup(0x40000092, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000092, "으음.. 이상하군. 분명히 여기가 맞을텐데..으음..");
AddDialog(0x40000092, 1, 0, "내 앞의 절벽밑에는 아주 특이하게 생긴 몬스터를 목격했다는 모험자들이 있어 그 몬스터에 관한 정보를 모으기위해 치켜보고 있는 중이지.");

/////////////////////////////////////////////////////////////////////////////////////
/////////////						이란샤 조사관						/////////////
/////////////////////////////////////////////////////////////////////////////////////

SetNPC(1, 0x40000093, 0x10000001, false, "NPC_W06.GCMDS", "레나");
SetPosition(0x40000093, 3.817, 1446.86, 151.50, 2763.31);
SetNPCAttribute(0x40000093, 6, 1 );
AddPopup(0x40000093, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000093, "흠.. 보면 볼수록 놀랍단말야.. 고대엔 어떻게 이런 것을 지을 수 있었을까..");
AddDialog(0x40000093, 1, 0, "이 고대에 만들어진 탑에 대해 흥미가 생겨 조사를 하고있는 중이죠.\\만약, 탑을 건설할때 사용한 기술을 일부분이라도 얻을 수 있다면,\\현재 제가 하고있는 연구에 큰 도움이 될텐데.\\혹시, 이 탑에대한 정보가 있다면 제게 알려주시겠어요?");

/////////////////////////////////////////////////////////////////////////////////////
/////////////						북부임시캠프						/////////////
/////////////////////////////////////////////////////////////////////////////////////

SetNPC(1, 0x40000094, 0x10000001, false, "NPC_M14.GCMDS", "아레스");
SetPosition(0x40000094, 5.187, 1446.73, 120.83, 2607.81);
SetNPCAttribute(0x40000094, 6, 1 );
AddPopup(0x40000094, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000094, "자네도 쉬러 왔나? 하긴, 사냥을 하다가 피곤할때는 잠시 쉬는 게 좋지.");
AddDialog(0x40000094, 1, 0, "이 주위에서 사냥을 하는 것은 좀 힘든 편이지 않나?\\뭐, 이 곳이 이 지역에서 가장 강한몬스터들이 몰려있다는 것을 생각하면 당연한 일이라고 생각되지만 말야.");

/////////////////////////////////////////////////////////////////////////////////////
/////////////					오크요새레인져캠프						/////////////
/////////////////////////////////////////////////////////////////////////////////////

SetNPC(1, 0x40000095, 0x10000001, false, "NPC_M14.GCMDS", "크레이");
SetPosition(0x40000095, 3.017, 2905.98, 110.26, 2524.31);
SetNPCAttribute(0x40000095, 6, 1 );
AddPopup(0x40000095, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000095, "여기까지 온 자네에겐 미안하지만, 난 지금 오크들의 동태를 살펴야하니 방해하지 말도록..");
AddDialog(0x40000095, 1, 0, "오크들중엔 마법을 사용할 줄 아는 오크들이 늘어가고 있어.\\게다가, 일반적인 오크들도 조금 세분화 된 것 같고..\\아무튼 무엇인가 큰일이 벌어질 것 같아 감시를 늦추지 않고 있는 중이야.");

SetNPC(1, 0x40000096, 0x10000001, false, "NPC_M05.GCMDS", "스테판");
SetPosition(0x40000096, 1.683, 2943.08, 139.55, 2580.93);
SetNPCAttribute(0x40000096, 6, 1 );
AddPopup(0x40000096, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000096, "음..대체 어디에서 오크들이 자꾸 나타나는 건지..분명히 다른 존에서 건너오는 건 확실한데..");
AddDialog(0x40000096, 1, 0, "걸어서 이 지역으로 들어오는 통로인 이 곳을 계속 감시를 했지만, 이 정도의 수가 모일정도로 오크들이 온 것은 보지 못했는데, 날이 지날때 마다 오크들의 수가 조금씩 증가하더군.\\분명, 어디엔가 우리들이 모르는 통로가 존재 한다는 이야기인데, 조사를 하고 싶어도 요새 내에있는 오크들 때문에 조사하지를 못하고 있는 상태라네..");

SetNPC(1, 0x40000097, 0x10000001, false, "NPC_W06.GCMDS", "크리스");
SetPosition(0x40000097, 3.100, 2663.38, 106.89, 2550.73);
SetNPCAttribute(0x40000097, 6, 1 );
AddPopup(0x40000097, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000097, "여긴 아주 위험한 장소이니 가능한 조용히 해주겠어요?");
AddDialog(0x40000097, 1, 0, "전 오크요새에서 빠져나가는 오크들을 감시하는 중이죠.");


/////////////////////////////////////////////////////////////////////////////////////
/////////////					서쪽감시초소							/////////////
/////////////////////////////////////////////////////////////////////////////////////

SetNPC(1, 0x40000098, 0x10000001, false, "NPC_M13.GCMDS", "데이먼");
SetPosition(0x40000098, 4.747, 1116.95, 50.85, 1900.52);
SetNPCAttribute(0x40000098, 6, 1 );
AddPopup(0x40000098, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000098, "내 임무는 여기서 동족평야의 몬스터를 감시하는 것이지..");
AddDialog(0x40000098, 1, 0, "내 임무는 이 밑을 통해 마을로 진입하는 몬스터가 없도록 하고 서부평야의 몬스터들의 움직임을 감시하는 것이지.");
/// AddQuest(0x40000098, 0x0105, 17, 20, 4095, 0, "nWestcamp1701");	//1차 추가 퀘스트

/////////////////////////////////////////////////////////////////////////////////////
/////////////					남쪽임시캠프							/////////////
/////////////////////////////////////////////////////////////////////////////////////

SetNPC(1, 0x40000099, 0x10000001, false, "NPC_M05.GCMDS", "밀리언");
SetPosition(0x40000099, 5.207, 1222.85, 60.84, 1598.14);
SetNPCAttribute(0x40000099, 6, 1 );
AddPopup(0x40000099, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000099, "에휴.. 사냥에 열중하느라 마법력이 다 소모된 것을 잊다니.. 조심하도록 해야지..");
AddDialog(0x40000099, 1, 0, "마법사는 사냥시에 자신의 마법력인 MP의 관리에 주의를 하게나.\\MP가 없으면 마법을 사용하지 못하고 마법을 사용하지 못하는 마법사는 일반인과 다를게 없으니 조심하게나.");

/////////////////////////////////////////////////////////////////////////////////////
/////////////					악마의대지 임시캠프						/////////////
/////////////////////////////////////////////////////////////////////////////////////

SetNPC(1, 0x4000009A, 0x10000001, false, "NPC_M04.GCMDS", "클레이브");
SetPosition(0x4000009A, 4.927, 2483.01, 101.59, 1676.79);
SetNPCAttribute(0x4000009A, 6, 1 );
AddPopup(0x4000009A, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000009A, "분명히 이곳엔 무엇인가 있기는 한데 그것을 모르겠으니..음..좀더 조사를 해봐야 겠군..");
AddDialog(0x4000009A, 1, 0, "난 '악마의 대지'라 불리는 이곳을 조사하는 중이지.\\어느날 갑자기 이곳의 모든 주민들이 죽었다는 것도 그렇고 이 곳을 지칭하는 명칭도 그렇고 상당히 의문점이 많은 곳이라 생각되지 않나?\\그래서 난 그 비밀을 풀기위해 이 곳을 조사하는 중이라네.\\혹시, 자네도 이 곳에서 사냥하다가 단서가 될만한 것이 있으면 나에게 알려주게나.");

/////////////////////////////////////////////////////////////////////////////////////
/////////////					용머리던전 임시캠프						/////////////
/////////////////////////////////////////////////////////////////////////////////////

SetNPC(1, 0x4000009B, 0x10000001, false, "NPC_M14.GCMDS", "카트라");
SetPosition(0x4000009B, 0.103, 1306.68, 78.85, 468.59);
SetNPCAttribute(0x4000009B, 6, 1 );
AddPopup(0x4000009B, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000009B, "여기까지 온 것을 보니 자네도 상당한 실력을 가졌군. 하지만 조심하게나..");
AddDialog(0x4000009B, 1, 0, "이 유적이 '용머리 던전'이라 불리게 된 이유는 유적에 붙어있는 용머리의 형상을 한 바위와 폐허가 된 유적내부 때문이지.\\던전내에는 상당히 강력한 몬스터들이 돌아다니니 자신의 체력관리에 주의를 하게나.");

/////////////////////////////////////////////////////////////////////////////////////
/////////////					북쪽해안 임시캠프						/////////////
/////////////////////////////////////////////////////////////////////////////////////

SetNPC(1, 0x4000009C, 0x10000001, false, "NPC_W06.GCMDS", "제이시아");
SetPosition(0x4000009C, 4.397, 2929.03, 22.94, 1249.13);
SetNPCAttribute(0x4000009C, 6, 1 );
AddPopup(0x4000009C, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000009C, "여기는 리자드맨들의 소굴과 같은 곳이니 사냥할때 조심하도록 해요.");
AddDialog(0x4000009C, 1, 0, "이 휴식처에서 좀더 안쪽으로 들어가면 대장격인 리자드맨이 있죠.\\실력에 자신이 있다면 사냥을 해보도록 하세요.");

/////////////////////////////////////////////////////////////////////////////////////
