/// 알디아 NPC_01
SetNPC(1, 0x4000000A, 0x10000001, false, "NPC_M03.GCMDS", "페이빈");
SetPosition(0x4000000A, 0.293, 2765.24, 23.44, 712.50);
SetNPCAttribute(0x4000000A, 6, 1 );
AddPopup(0x4000000A, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000000A, "치워도 치워도 계속 쌓이기만 하니..이 화물들을 언제 다 치우지..?");
AddDialog(0x4000000A, 1, 0, "이 상자들은 모두 수도에서 이곳으로 운반해온 무기와 갑옷, 그리고 일반적인 생활물품들이지만 워낙 일손이 모자르다 보니 일단 이렇게 내려놓은 뒤에 정리를 하게 되었지.\\이런, 쓰잘데없는 푸념을 하고 말았군.");

/// 알디아 NPC_02
SetNPC(1, 0x4000000C, 0x10000001, false, "NPC_M11.GCMDS", "안내원");
SetPosition(0x4000000C, 2.327, 2714.95, 24.22, 585.82);
SetNPCAttribute(0x4000000C, 6, 1 );
AddPopup(0x4000000C, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000000C, "어서 오십시오. 그랜드코스트 지역의 알디아 항구에 오신걸 환영합니다.");
AddDialog(0x4000000C, 1, 0, "전 '알디아 항구' 주위에 관해 안내를 하기위해 왕국의 관리소에서 파견된 공무원입니다.");
/// AddQuest(0x4000000C, 0x0001, 1, 10, 4095, 0, "nAldia0101");
