/// 유니테 길드관리대표
SetNPC(2, 0x40001072, 0x10000001, false, "NPC_A_blacksmith.GCMDS", "<길드관리대표>");
SetPosition(0x40001072, 6.247, 2016.67, 61.01, 1706.01);
SetNPCAttribute(0x40001072, 28, 2 );
AddPopup(0x40001072, 10000, 0, "설명듣기", 0, 0 , 16715775);
AddPopup(0x40001072, 222, 0, "길드만들기", 0, 0 , 16715775);
AddWords(0x40001072, "아칸에게 있어 생사를 함께할 전우가 있다는건 귀중한 명예중에 하나라고 할 수 있지.");
AddDialog(0x40001072, 1, 0, "●길드가입신청은 화면의 우하단 [길드]메\\ 뉴에서 가능합니다.\\●길드를 창단하려면 1000000(백만)Gold의\\ 화폐가 필요하며, 30LV 이상 되어야 합니\\ 다.\\\\\\●길드를 확장할때는 다음과 같은 조건\\을 만족시켜야 합니다.\\======================================\\  길드 명성치와 확장 가능 인원 제한 값\\--------------------------------------\\  필요명성치 | 제한인원 |    필요금액\\--------------------------------------\\             0   |     10     |   1,000,000\\        2000   |     20     |   5,000,000\\       10000   |     30     |  10,000,000\\       25000   |     40     |  50,000,000\\       50000   |     50     | 100,000,000\\======================================\\\\※주의-길드 결성 후 24시간 이내에 자신을\\ 포함한 길드의 인원이 4인 이상이 되어야\\  길드가 유지 됩니다.");
