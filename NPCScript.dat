/////////////////////////////////////////////////////////////////////////////////////

SetNPC(1, 0x4000009D, 0x10000001, false, "NPC_M14.GCMDS", "모드레이");
SetPosition(0x4000009D, 0.163, 2463.94, 29.92, 901.30);
SetNPCAttribute(0x4000009D, 6, 1 );
AddPopup(0x4000009D, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000009D, "이곳은 평화로워 보이지만 하루에도 수백명의 사람들이 기절해서 실려 나간다네.");
AddDialog(0x4000009D, 1, 0, "사실 여기서 있다보면 많은 사람들이 몬스터에게 당해서 죽어나가는것을 볼수 있다네.\\라폰녀석들은 초보가 잡기에는 다소 쎈놈들이네.\\물론, 상대가 강하면 도망치는 것도 살아남기 위한 방법이지.");

