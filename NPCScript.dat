// "고대인"
SetNPC(12, 0x40012117, 0x10000001, false, "NPC_Quest_Ancient.GCMDS", "빌\\<고대인의 후예>");
SetPosition(0x40012117, 1.014, 822.05, 158.27, 852.92);
SetNPCAttribute(0x40012117, 6, 0 );
AddPopup(0x40012117, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x40012117, "무슨일이시죠?");
AddDialog(0x40012117, 1, 0, "[차원의 문]을 전공하는 이들에게 가장 시급한 문제는 [벨제뷔트]의 등장이 아닙니다.\\어떻게 하면 [차원의 문]의 빛의 삼투압을 이용하여 보다 신속하게 다른 차원으로 날아갈 수 있을까?..이죠.");

