AddPopup(0x40000088, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40000088, "어서 오십시오. 여기는 그랜드코스트 동쪽지역 캠프, '감시자'입니다.");
AddDialog(0x40000088, 1, 0, "이 곳은 오크요새의 오크들을 감시하기위해 세워진 캠프로서 요즘 위험수위까지 늘어난 오크들 덕에 매일 철야로 경계를 하고 있는 상태입니다.\\아직까지는 사냥을 하는데 무리는 없지만, 충분히 주의를 해주십시오.");

