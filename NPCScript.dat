SetNPC(1, 0x4000011A, 0x10000001, false, "NPC_H_depositary.GCMDS", "<DragonTrans 본점>");
SetPosition(0x4000011A, 0.736, 1461.00, 9.26, 1971.59);
SetNPCAttribute(0x4000011A, 19, 1 );
AddPopup(0x4000011A, 10000, 0, "대화하기", 0, 0 , 16715775);
AddPopup(0x4000011A, 10000, 0, "설명듣기", 0, 0 , 16715775);
AddPopup(0x4000011A, 107, 0, "물품보관함", 0, 0 , 16715775);
AddWords(0x4000011A, "어서오십시오. DragonTrans 물류센터 본점입니다.");
AddDialog(0x4000011A, 1, 0, "전에 한번 관리인 몰래 용을 보러갔다가 용이 잠을 깨는 바람에 죽을뻔 했소.\\용은 길들인 자 이외에는 따르지 않는다고 하더구려.");                          
AddDialog(0x4000011A, 2, 0, "보관소를 처음 사용하시면 보관함 한개는 무료로 이용하실 수 있습니다.\\ 추가로 보관함을 이용하시려면 '사용불가'탭을 클릭하시면 보관함을 추가로 구입할 수 있습니다.\\ \\또한 저희는 물건을 맡길때마다 수수료를 받고 있습니다.\\맡길 물건은 신중히 선택해 주십시오\\ \\ 비밀번호는 저장해 두시고 사용할 수 있지만 물건을 분실했을 경우 본사는 책임지지 않사오니 비밀번호를 잘 관리 해주시기 바랍니다.\\ \\비밀번호를 분실했을 때에는 홈페이지로 문의해주시기 바랍니다.");

