SetNPC(4, 0x4000301C,  0x10000001, false, "NPC_M14.GCMDS", "레이온");
SetPosition(0x4000301C, 4.380, 1946.84, 10.00, 1034.18);
SetNPCAttribute(0x4000301C, 6, 1 );
AddPopup(0x4000301C, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000301C, "아니..이게 누군가? 여기서도 나의 멋진모습을 보다니 행운아로군!");
AddDialog(0x4000301C, 1, 0, "후후.. 자네도 수없이 몬스터에게 당하면서 열\\심히 모험을 하다보면 나처럼 멋진 장비를 가질\\수 있을거야..\\음? 난 여기서 뭐하냐고? 이 몸의 아까운 시\\간을 소비해 자네같은 초보 모험자들에게 멋진\\모습을 보여주어 모험의욕을 자극하기 위해 있는\\거지..");


//뉴베린 레비너트
SetNPC(4, 0x40009002, 0x10000001, false, "NPC_W06.GCMDS", "레비너트");
SetPosition(0x40009002, 2.338, 2002.16, 10.00, 1007.86);
SetNPCAttribute(0x40009002, 6, 1 );
AddPopup(0x40009002, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40009002, "겉보기보단 바쁘니까 말벗이 필요한 거라면 다른 사람을 찾아보는게 나을거 같군요.");
AddDialog(0x40009002, 1, 0, "뉴베린은 베린보다 훨씬 안전한 곳이지만, 아칸들이 이곳까지 오지 않는다는 법은 없죠.");
/// AddQuest(0x40009002, 0x0120, 47, 50, 4095, 0, "nNew4701"); //1차 추가 퀘스트

SetNPC(4, 0x4000301D, 0x10000001, false, "NPC_M12.GCMDS", "경비병");
SetPosition(0x4000301D, 4.012, 1962.25, 10.00, 990.21);
SetNPCAttribute(0x4000301D, 6, 1 );
AddPopup(0x4000301D, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000301D, "반갑습니다. 이곳은 사이너 아일랜드 최초의 마을 뉴베린 항구 입니다.");
AddDialog(0x4000301D, 1, 0, "수도에서 이 곳으로 오는 이동로는 몇 개가 존\\재하지만, 배를 이용해서 오는 것이 가장 안전\\하면서 빠른 이동로죠. 그래서 이 지역으로 오\\는 물자는 대부분 배를 이용해 가져오죠.");

SetNPC(4, 0x4000301E, 0x10000001, false, "NPC_M12.GCMDS", "경비병");
SetPosition(0x4000301E, 0.102, 2047.46, 8.278, 939.93);
SetNPCAttribute(0x4000301E, 6, 1 );
AddPopup(0x4000301E, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000301E, "반갑습니다. 이곳은 사이너 아일랜드 최초의 마을 뉴베린 항구 입니다.");
AddDialog(0x4000301E, 1, 0, "수도에서 이 곳으로 오는 이동로는 몇 개가 존\\재하지만, 배를 이용해서 오는 것이 가장 안전\\하면서 빠른 이동로죠. 그래서 이 지역으로 오\\는 물자는 대부분 배를 이용해 가져오죠.");

SetNPC(4, 0x4000301F, 0x10000001, false, "NPC_W03.GCMDS", "마오");
SetPosition(0x4000301F, 3.420, 2015.13, 9.55, 967.36);
SetNPCAttribute(0x4000301F, 6, 1 );
AddPopup(0x4000301F, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x4000301F, "이곳은 얼핏보기에 더워보이지만 밤이되면 꽤 선선해요...");
AddDialog(0x4000301F, 1, 0, "열심히 수련하지 않으면 언젠가는 이 \\마을이 아칸족에게 밀릴지도 모르죠.\\그런날이 오는걸 막기위해 많은 사람들이\\더욱 고레벨의 몬스터를 잡기위해\\이곳으로 온답니다. 자신을 시험하는\\거죠. 여기서 버틸 수 없다면\\다시 테시티오로 돌아 가세요.");

SetNPC(4, 0x40003020, 0x10000001, false, "NPC_W03.GCMDS", "카트린느");
SetPosition(0x40003020, 5.723, 2036.68, 10.00, 1011.25);
SetNPCAttribute(0x40003020, 6, 1 );
AddPopup(0x40003020, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40003020, "여기까지 오시는데 피곤하셨죠? 가끔은 휴식도 필요하니 푹 쉬세요.");
AddDialog(0x40003020, 1, 0, "아무래도 이곳 여관은 장사가 잘 안되겠죠?\\다른일을 찾아보려고 해도\\적성에 맞는걸 못 찾겠어요.\\이렇게 살다보면 돈 많고 잘생긴 남자 \\만나서 시집이나 가버릴지도 모르죠.");

SetNPC(4, 0x40003021, 0x10000001, false, "NPC_W02.GCMDS", "카산드라");
SetPosition(0x40003021, 0.096, 1970.19, 9.99, 984.14);
SetNPCAttribute(0x40003021, 6, 1 );
AddPopup(0x40003021, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40003021, "뉴베린 항구는 기존 베린항구의 주민들이 새로 이주해 만든곳입니다.");
AddDialog(0x40003021, 1, 0, "이 마을은 사람들이 일군 결실이죠.\\모두들 많이 노력했어요. 바닷가라 덥고\\마을도 작지만 우린 이곳을 사랑해요.");

SetNPC(4, 0x40003022, 0x10000001, false, "NPC_M03.GCMDS", "무하드");
SetPosition(0x40003022, 6.036, 2039.70, 8.23, 939.03);
SetNPCAttribute(0x40003022, 6, 1 );
AddPopup(0x40003022, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40003022, "어서오게. 선착장은 늘 바빠서 정신이 없다네.");
AddDialog(0x40003022, 1, 0, "어서 빨리 이 섬을 탐험하고 싶어서\\제대로 준비하지 않고 무리하게 출발했다가는\\그대로 황천길로 가야할걸세.\\이곳의 몬스터들은 자네가 그동안 보아온\\놈들과는 차원이 틀려.");

SetNPC(4, 0x40003023, 0x10000001, false, "NPC_W03.GCMDS", "라자드");
SetPosition(0x40003023, 0.693, 2047.19, 10.10, 1050.42);
SetNPCAttribute(0x40003023, 6, 1 );
AddPopup(0x40003023, 10000, 0, "대화하기", 0, 0 , 16715775);
AddWords(0x40003023, "아름다운 해안가를 거닐어보시지 않겠어요?네?저하고 같이요?");
AddDialog(0x40003023, 1, 0, "언젠가는 결혼해야한다고 생각하고는 있지만\\아직 마음에 드는 남자를 만나지 못했죠.\\언젠가는 성실하고 저만 생각해주는\\그런 사람을 만날 수 있겠죠?");



