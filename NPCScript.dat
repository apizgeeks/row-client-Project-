// "신의해적단 항해사"
SetNPC(12, 0x40012089, 0x10000001, false, "NPC_U_PirateCaptain.GCMDS", "리게르 윌\\<신의 해적단 1등 항해사>");
SetPosition(0x40012089, 0.921, 2838.13, 16.08, 2557.71);
SetNPCAttribute(0x40012089, 6, 0 );
AddPopup(0x40012089, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x40012089, "[신의 대지]역시 세상의 끝이 아닌거야..");
AddDialog(0x40012089, 1, 0, "난 한 때 [미하엘]과 함께 바다를 누비는 악명높은 해적선장이었지만 말이야..\\지금은 그저 이 넓디 넓은 세상을 내 배한척으로 누비며 세상의 모든 것을 경험해보고 싶은 한 남자일 뿐이지 하핫!\\혹시나 진부하긴 하지만, 전설이나 희귀한 정보가 궁금할 땐 이 [리게르 윌]를 찾아와!");

