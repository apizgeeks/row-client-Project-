AddDialog(0x40012070, 1, 0, "이곳에서 [세비지 포쳐]가 아닌 다른 덩치큰 종족을 자주 보게 되다니 신기해요.\\[세비지 포쳐]들은 무서워요..");


// "얼어붙은 초원 모닥불2"
SetNPC(12, 0x4001207A, 0x10000001, false, "NPC_SnowMan.GCMDS", "디아미르\\<스노우림프 종족>");
SetPosition(0x4001207A, 2.008, 1143.13, 149.98, 2899.29);
SetNPCAttribute(0x4001207A, 6, 0 );
AddPopup(0x4001207A, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x4001207A, "바깥에서는 모닥불을 추위를 쫓는데 이용하기 한다는데..사실인가요?");
AddDialog(0x4001207A, 1, 0, "반갑습니다.\\[세비지 포쳐]들은 좀더 설원의 안쪽으로 들어가면 볼 수 있는 종족이랍니다.\\그들은 보이는건 뭐든지 잡으려고 한답니다.");


// "얼어붙은 초원 집앞1"
SetNPC(12, 0x4001207B, 0x10000001, false, "NPC_SnowManYoung.GCMDS", "트리트란델\\<스노우림프 종족>");
SetPosition(0x4001207B, 1.634, 1110.18, 157.55, 2913.81);
SetNPCAttribute(0x4001207B, 6, 0 );
AddPopup(0x4001207B, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x4001207B, "[엘리오르]에 오신걸 환영합니다.");
AddDialog(0x4001207B, 1, 0, "옆은 내 아들녀석인 [시두르]입니다.\\한창 귀여울 때죠..");

//AddQuest(0x4001207B, 0xf081);


// "얼어붙은 초원 두번째 모닥불1"
SetNPC(12, 0x4001207C, 0x10000001, false, "NPC_SnowManChild.GCMDS", "시두르\\<스노우림프 종족>");
SetPosition(0x4001207C, 2.021, 1110.01, 157.71, 2914.90);
SetNPCAttribute(0x4001207C, 6, 0 );
AddPopup(0x4001207C, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x4001207C, "안녕하세요~ 나빠 보이진 않아요..");
AddDialog(0x4001207C, 1, 0, "있잖아요..\\가끔 이곳에 찾아오는 [롱기어족]들은 신기한 물건들을 많이 가지고 있어서 참 좋아요..히이~");


// "얼어붙은 초원 집앞2"
SetNPC(12, 0x4001207D, 0x10000001, false, "NPC_SnowGirlChild.GCMDS", "세리스라시엘\\<스노우림프 종족>");
SetPosition(0x4001207D, 0.098, 1093.31, 158.72, 2862.38);
SetNPCAttribute(0x4001207D, 6, 0 );
AddPopup(0x4001207D, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddWords(0x4001207D, "와..반가워요..헤헤");
AddDialog(0x4001207D, 1, 0, "쉿..\\지금 숨어있는 중이라구요..");

//AddQuest(0x4001207D, 0xf078);

// "얼어붙은 초원 던젼앞 잡화상인"
SetNPC(12, 0x4001207E, 0x10000001, false, "NPC_SnowGirl.GCMDS", "트라라위엘\\<스노우림프 종족>");
SetPosition(0x4001207E, 1.227, 1081.08, 159.00, 2886.39);
SetNPCAttribute(0x4001207E, 15, 0 );
AddPopup(0x4001207E, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x4001207E, 401, 13, "잡화상점", 0, 0 , 16715775);
AddWords(0x4001207E, "[스노우림프 족]의 마을 [엘리오르(Elior)]에 오신걸 환영해요.");
AddDialog(0x4001207E, 1, 0, "반가워요.\\[스노우림프 종족]의 [트라라위엘]이라고 해요.\\저흰 가능하면 다른 종족눈에 안띄려고 이곳에 살지만, 우리 [스노우림프 족]에게 피해를 주지 않는다면 어떤 종족이든 환영이랍니다.\\혹시 간단한 물건이 필요하다면 제게 오시면 되요.\\잠깐이겠지만 이곳에서의 시간이 좋은 추억이 되었으면 좋겠어요.");

