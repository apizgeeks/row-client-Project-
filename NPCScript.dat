AddPopup(0x40008102, 10000, 0, "대화 하기", 0, 0 , 16715775);
AddPopup(0x40008102, 105, 0, "신의대지 해적마을로", 0, 0 , 16715775);
AddWords(0x40008102, "어서 오십시오. 신의대지로의 이동이 필요하십니까?");
AddDialog(0x40008102, 1, 0, "신의대지는 아칸의 영웅이라 불리는 [라타르]에 의해 발견된 대륙입니다.\\지금은 평화와 자유를 주장한  [미하엘]이라는 인간이 전쟁에의 자유를 상징하는 [신의 해적단]이라는 무리를 이끌고 [신의 대지]를 발전시키고 있지요.\\                                       \\발견된지 10년정도 밖에 안된 대륙이기 때문에 새로운 것들을 찾으려는 모험가들이 많이 찾고 있습니다.");
AddZoneMove(0x40008102, 12, 2824.09, 13.00, 2544.81);


